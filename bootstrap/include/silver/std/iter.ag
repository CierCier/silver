import std.optional;

// IntoIterator: types that can be iterated over via into_iter(self).
// Required method: Iterator into_iter(self);
trait IntoIterator<Self> {
    type Item;
    type IntoIter;
    IntoIter into_iter(Self self);
}

// Iterator: types that yield values via next(&self).
trait Iterator<Self> {
    type Item;
    Optional<Item> next(Self* self);
}

// IntoIteratorPtr: yields mutable pointers to elements.
trait IntoIteratorPtr<Self> {
    type Item;
    type IntoIter;
    IntoIter into_iter_ptr(Self self);
}

// IntoIteratorConstPtr: yields const pointers to elements.
trait IntoIteratorConstPtr<Self> {
    type Item;
    type IntoIter;
    IntoIter into_iter_const_ptr(Self self);
}
