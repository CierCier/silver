// 64x64 -> high-64 multiply with rounding (DiyFp multiplication).
FmtDiyFp __fmt_mul(FmtDiyFp x, FmtDiyFp y) {
    u64 M32 = (u64)4294967295;
    u64 a = __fmt_lshr(x.f, 32);
    u64 b = x.f & M32;
    u64 c = __fmt_lshr(y.f, 32);
    u64 d = y.f & M32;
    u64 ac = a * c;
    u64 bc = b * c;
    u64 ad = a * d;
    u64 bd = b * d;
    u64 tmp = __fmt_lshr(bd, 32) + (ad & M32) + (bc & M32);
    tmp = tmp + (u64)2147483648; // round
    FmtDiyFp r;
    r.f = ac + __fmt_lshr(ad, 32) + __fmt_lshr(bc, 32) + __fmt_lshr(tmp, 32);
    r.e = x.e + y.e + 64;
    return r;
}

// Decimal digit count of a value in [0, 10^9) (rapidjson CountDecimalDigit32).
i64 __fmt_count_digits(i64 n) {
    if (n < 10) { return 1; }
    if (n < 100) { return 2; }
    if (n < 1000) { return 3; }
    if (n < 10000) { return 4; }
    if (n < 100000) { return 5; }
    if (n < 1000000) { return 6; }
    if (n < 10000000) { return 7; }
    if (n < 100000000) { return 8; }
    return 9;
}

// Weed out the last digit while the shorter form still lies within the
// rounding interval (rapidjson GrisuRound).
void __fmt_grisu_round(u8* buf, i64 len, u64 delta, u64 rest, u64 ten_kappa, u64 wpw) {
    while (__fmt_ult(rest, wpw)
        && !__fmt_ult(delta - rest, ten_kappa)
        && (__fmt_ult(rest + ten_kappa, wpw)
            || __fmt_ult(rest + ten_kappa - wpw, wpw - rest))) {
        buf[len - 1] = buf[len - 1] - (u8)1;
        rest = rest + ten_kappa;
    }
}

// Digit generation (rapidjson DigitGen). W ~ value, Mp ~ upper boundary,
// delta = Mp - Mm. Writes digits to buf, sets *out_len, adjusts *inout_k.
void __fmt_digit_gen(FmtDiyFp w, FmtDiyFp mp, u64 delta, u8* buf, i64* out_len, i64* inout_k) {
    i64 neg_e = 0 - mp.e; // in [32, 63]
    u64 onef = (u64)1 << (u64)neg_e;
    u64 wpwf = mp.f - w.f;
    i64 p1 = (i64)__fmt_lshr(mp.f, neg_e); // < 10^9, so signed math is safe
    u64 p2 = mp.f & (onef - (u64)1);
    i64 kappa = __fmt_count_digits(p1);
    i64 len = 0;
    i64 k = *inout_k;

    while (kappa > 0) {
        i64 pw = (i64)__fmt_pow10(kappa - 1);
        i64 d = p1 / pw;
        p1 = p1 % pw;
        if (d != 0 || len != 0) {
            buf[len] = (u8)(48 + d);
            len = len + 1;
        }
        kappa = kappa - 1;
        u64 tmp = ((u64)p1 << (u64)neg_e) + p2;
        if (!__fmt_ult(delta, tmp)) { // tmp <= delta
            *inout_k = k + kappa;
            *out_len = len;
            __fmt_grisu_round(buf, len, delta, tmp, __fmt_pow10(kappa) << (u64)neg_e, wpwf);
            return;
        }
    }

    // kappa == 0: generate fractional digits.
    while (true) {
        p2 = p2 * (u64)10;
        delta = delta * (u64)10;
        i64 d = (i64)__fmt_lshr(p2, neg_e);
        if (d != 0 || len != 0) {
            buf[len] = (u8)(48 + d);
            len = len + 1;
        }
        p2 = p2 & (onef - (u64)1);
        kappa = kappa - 1;
        if (__fmt_ult(p2, delta)) {
            *inout_k = k + kappa;
            *out_len = len;
            __fmt_grisu_round(buf, len, delta, p2, onef, wpwf * __fmt_pow10(0 - kappa));
            return;
        }
    }
}

// Grisu2 driver: mbits is the IEEE-754 bit pattern of a positive, finite,
// nonzero f64. Produces the digit string (no leading/trailing formatting) and
// the decimal exponent K such that value ~= digits * 10^K.
void __fmt_grisu2(u64 mbits, u8* digits, i64* out_len, i64* out_k) {
    u64 FRAC_MASK = (u64)4503599627370495;  // 2^52 - 1
    u64 HIDDEN = (u64)4503599627370496;     // 2^52
    i64 biased = (i64)(__fmt_lshr(mbits, 52) & (u64)2047);
    u64 vf = mbits & FRAC_MASK;
    i64 ve = -1074;
    if (biased != 0) {
        vf = vf + HIDDEN;
        ve = biased - 1075;
    }

    // Upper boundary: ((f << 1) + 1, e - 1), normalized (NormalizeBoundary).
    u64 plf = (vf << (u64)1) + (u64)1;
    i64 ple = ve - 1;
    while ((plf & (u64)9007199254740992) == (u64)0) { // hidden << 1 = 2^53
        plf = plf << (u64)1;
        ple = ple - 1;
    }
    plf = plf << (u64)10;
    ple = ple - 10;

    // Lower boundary. A power-of-two significand has a half-size gap below it,
    // except at the smallest normal exponent where the subnormal gap is equal
    // (rapidjson omits the biased > 1 refinement; Loitsch includes it).
    u64 mif = (vf << (u64)1) - (u64)1;
    i64 mie = ve - 1;
    if (vf == HIDDEN && biased > 1) {
        mif = (vf << (u64)2) - (u64)1;
        mie = ve - 2;
    }
    mif = mif << (u64)(mie - ple);
    mie = ple;

    // Normalize the value itself.
    i64 shift = __fmt_clz64(vf);
    FmtDiyFp w;
    w.f = vf << (u64)shift;
    w.e = ve - shift;

    // Cached power selection (rapidjson GetCachedPower).
    f64 dk = ((f64)(0 - 61 - ple)) * 0.30102999566398114 + 347.0;
    i64 k = (i64)dk;
    if (dk - (f64)k > 0.0) {
        k = k + 1;
    }
    i64 index = k / 8 + 1; // k >= 0 here, so / matches >>
    i64 bigk = 0 - (-348 + index * 8);

    FmtDiyFp cmk;
    cmk.f = __fmt_cpow_f(index);
    cmk.e = __fmt_cpow_e(index);

    FmtDiyFp wq = __fmt_mul(w, cmk);
    FmtDiyFp pl;
    pl.f = plf;
    pl.e = ple;
    FmtDiyFp wp = __fmt_mul(pl, cmk);
    FmtDiyFp mi;
    mi.f = mif;
    mi.e = mie;
    FmtDiyFp wm = __fmt_mul(mi, cmk);
    wm.f = wm.f + (u64)1;
    wp.f = wp.f - (u64)1;
    __fmt_digit_gen(wq, wp, wp.f - wm.f, digits, out_len, &bigk);
    *out_k = bigk;
}

// Scratch space for Grisu digits (never more than ~18 digits).
struct FmtDigitsBuf {
    u8 data[32];
}

// f64 -> text. Matches Rust `{}` Display for f64: shortest round-trip digits,
// always positional notation, "NaN"/"inf"/"-inf" for specials, "-0" for
// negative zero. Worst-case output length is 326 bytes (5e-324): size buffers
// with FTOA_MAX_LEN.
pub const i64 FTOA_MAX_LEN = 344;

pub i64 ftoa(f64 v, u8* buf) {
    f64 local = v;
    u64* bp = (u64*)&local;
    u64 bits = *bp;
    u64 SIGN_BIT = (u64)9223372036854775808;
    u64 MAG_MASK = (u64)9223372036854775807;
    u64 FRAC_MASK = (u64)4503599627370495;
    bool neg = (bits & SIGN_BIT) != (u64)0;
    u64 mbits = bits & MAG_MASK;
    i64 biased = (i64)__fmt_lshr(mbits, 52);
    u64 frac = mbits & FRAC_MASK;

    if (biased == 2047) {
        if (frac != (u64)0) {
            // Rust prints "NaN" regardless of sign.
            buf[0] = (u8)78;  // 'N'
            buf[1] = (u8)97;  // 'a'
            buf[2] = (u8)78;  // 'N'
            return 3;
        }
        i64 n = 0;
        if (neg) {
            buf[0] = (u8)45; // '-'
            n = 1;
        }
        buf[n] = (u8)105;     // 'i'
        buf[n + 1] = (u8)110; // 'n'
        buf[n + 2] = (u8)102; // 'f'
        return n + 3;
    }

    i64 n = 0;
    if (neg) {
        buf[0] = (u8)45; // '-'
        n = 1;
    }
    if (mbits == (u64)0) {
        buf[n] = (u8)48; // '0'
        return n + 1;
    }

    FmtDigitsBuf db;
    u8* digits = (u8*)&db;
    i64 dlen = 0;
    i64 kexp = 0;
    __fmt_grisu2(mbits, digits, &dlen, &kexp);

    // Canonicalize: drop trailing zero digits that belong to the fraction.
    while (dlen > 1 && kexp < 0 && digits[dlen - 1] == (u8)48) {
        dlen = dlen - 1;
        kexp = kexp + 1;
    }

    if (kexp >= 0) {
        // digits followed by kexp zeros: an integer value.
        i64 i = 0;
        while (i < dlen) {
            buf[n] = digits[i];
            n = n + 1;
            i = i + 1;
        }
        i = 0;
        while (i < kexp) {
            buf[n] = (u8)48;
            n = n + 1;
            i = i + 1;
        }
        return n;
    }

    i64 point = dlen + kexp; // decimal point position within the digit string
    if (point > 0) {
        // dddd.dddd
        i64 i = 0;
        while (i < point) {
            buf[n] = digits[i];
            n = n + 1;
            i = i + 1;
        }
        buf[n] = (u8)46; // '.'
        n = n + 1;
        while (i < dlen) {
            buf[n] = digits[i];
            n = n + 1;
            i = i + 1;
        }
        return n;
    }

    // 0.000dddd
    buf[n] = (u8)48;     // '0'
    buf[n + 1] = (u8)46; // '.'
    n = n + 2;
    i64 zeros = 0 - point;
    i64 i = 0;
    while (i < zeros) {
        buf[n] = (u8)48;
        n = n + 1;
        i = i + 1;
    }
    i = 0;
    while (i < dlen) {
        buf[n] = digits[i];
        n = n + 1;
        i = i + 1;
    }
    return n;
}

// ---------------------------------------------------------------------------
// UTF-8 validation (exact, rejects overlongs/surrogates/out-of-range).
// ---------------------------------------------------------------------------

pub bool is_valid_utf8(u8* p, i64 len) {
    i64 i = 0;
    while (i < len) {
        i64 c = (i64)p[i] & (i64)255;
        if (c < 128) {
            i = i + 1;
        } else {
            i64 need = -1;
            i64 lo = 128;
            i64 hi = 191;
            if (c >= 194 && c <= 223) { need = 1; }
            if (c == 224) { need = 2; lo = 160; }
            if (c >= 225 && c <= 236) { need = 2; }
            if (c == 237) { need = 2; hi = 159; }
            if (c == 238 || c == 239) { need = 2; }
            if (c == 240) { need = 3; lo = 144; }
            if (c >= 241 && c <= 243) { need = 3; }
            if (c == 244) { need = 3; hi = 143; }
            if (need < 0) {
                return false;
            }
            if (i + need >= len) {
                return false;
            }
            i64 c1 = (i64)p[i + 1] & (i64)255;
            if (c1 < lo || c1 > hi) {
                return false;
            }
            i64 j = 2;
            while (j <= need) {
                i64 cj = (i64)p[i + j] & (i64)255;
                if (cj < 128 || cj > 191) {
                    return false;
                }
                j = j + 1;
            }
            i = i + need + 1;
        }
    }
    return true;
}

// Length of a NUL-terminated C string (pure Silver, no libc).
pub i64 cstr_len(u8* p) {
    i64 n = 0;
    while (((i64)p[n] & (i64)255) != 0) {
        n = n + 1;
    }
    return n;
}

// ---------------------------------------------------------------------------
// Frozen C-ABI print surface (c). Names and semantics mirror
// silver_runtime/src/runtime/ffi.rs exactly.
// ---------------------------------------------------------------------------

// Scratch buffer big enough for the longest positional f64 plus '\n'.
struct FmtPrintBuf {
    u8 data[352];
}

pub void silver_rt_print_i64(i64 v) {
    FmtPrintBuf b;
    u8* p = (u8*)&b;
    i64 n = itoa(v, p);
    p[n] = (u8)10; // '\n'
    write_stdout(p, n + 1);
}

pub void silver_rt_print_u64(u64 v) {
    FmtPrintBuf b;
    u8* p = (u8*)&b;
    i64 n = utoa(v, p);
    p[n] = (u8)10;
    write_stdout(p, n + 1);
}

pub void silver_rt_print_bool(u8 v) {
    FmtPrintBuf b;
    u8* p = (u8*)&b;
    i64 n = btoa(((i64)v & (i64)255) != 0, p);
    p[n] = (u8)10;
    write_stdout(p, n + 1);
}

pub void silver_rt_print_f64(f64 v) {
    FmtPrintBuf b;
    u8* p = (u8*)&b;
    i64 n = ftoa(v, p);
    p[n] = (u8)10;
    write_stdout(p, n + 1);
}

pub void silver_rt_print_cstr(char* ptr) {
    if (ptr == (char*)0) {
        write_stdout((u8*)"<null>\n", 7);
        return;
    }
    u8* p = (u8*)ptr;
    i64 len = cstr_len(p);
    if (is_valid_utf8(p, len)) {
        write_stdout(p, len);
        write_stdout((u8*)"\n", 1);
    } else {
        write_stdout((u8*)"<non-utf8>\n", 11);
    }
}

// C-friendly borrowed slice; layout matches SilverSlice in ffi.rs.
struct SilverSlice {
    u8* ptr;
    i64 len;
}

// NB: unlike the other print functions this does NOT append a newline for
// valid payloads (print! not println! in ffi.rs); the null case does.
pub void silver_rt_print_bytes(SilverSlice s) {
    if (s.ptr == (u8*)0) {
        write_stdout((u8*)"<null>\n", 7);
        return;
    }
    if (is_valid_utf8(s.ptr, s.len)) {
        write_stdout(s.ptr, s.len);
    } else {
        write_stdout((u8*)"<non-utf8>\n", 11);
    }
}

// Abort the process with SIGABRT, mirroring std::process::abort() as closely
// as raw syscalls allow. If SIGABRT is blocked or handled and returns, fall
// back to the default-SIGABRT exit status (128 + 6).
pub void silver_rt_abort() {
    i64 pid = sys_getpid();
    sys_kill(pid, 6); // SIGABRT
    sys_exit_group(134);
}

pub void silver_rt_abort_cstr(char* ptr) {
    if (ptr != (char*)0) {
        u8* p = (u8*)ptr;
        i64 len = cstr_len(p);
        // ffi.rs prints the message only when it is valid UTF-8.
        if (is_valid_utf8(p, len)) {
            write_stderr(p, len);
            write_stderr((u8*)"\n", 1);
        }
    }
    silver_rt_abort();
}
