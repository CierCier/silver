// std/fmt.ag — pure-Silver number->text formatting and raw print I/O.
//
// This module ports the frozen print surface of silver_runtime/src/runtime/ffi.rs
// to pure Silver. Output goes straight to the write(2) syscall via std.sys.linux;
// no libc printf/puts is used on any code path in this file.
//
// f64 formatting uses the Grisu2 algorithm (Loitsch 2010), ported from the
// rapidjson reference implementation (MIT), with digits rendered in positional
// decimal notation to match Rust's `{}` Display for f64 (which never uses
// scientific notation: 1e21 prints as "1000000000000000000000").
//
// NOTE on unsigned arithmetic: the current codegen lowers all integer division,
// remainder, comparison and right-shift as SIGNED operations regardless of the
// declared type, so this file implements logical-shift-right, unsigned compare
// and unsigned divide-by-10 manually on top of two's-complement i64 semantics.

import std.sys.linux;

// ---------------------------------------------------------------------------
// Raw fd writers (b): write the full buffer, retrying on EINTR/short writes.
// Returns the number of bytes written, or a negative errno on failure.
// ---------------------------------------------------------------------------

i64 __fmt_write_fd(i64 fd, u8* p, i64 len) {
    i64 written = 0;
    while (written < len) {
        i64 r = sys_write(fd, (i64)&p[written], len - written);
        if (r >= 0) {
            if (r == 0) {
                return written;
            }
            written = written + r;
        } else {
            if (r != -4) { // EINTR = 4
                return r;
            }
        }
    }
    return written;
}

pub i64 write_stdout(u8* p, i64 len) {
    return __fmt_write_fd(1, p, len);
}

pub i64 write_stderr(u8* p, i64 len) {
    return __fmt_write_fd(2, p, len);
}

// ---------------------------------------------------------------------------
// Unsigned helpers (codegen emits signed ops for u64, see note above).
// ---------------------------------------------------------------------------

// Logical (zero-filling) shift right.
u64 __fmt_lshr(u64 x, i64 n) {
    if (n <= 0) {
        return x;
    }
    if (n >= 64) {
        return (u64)0;
    }
    // Arithmetic shift by one, clear the smeared sign bit, then the remaining
    // shift is safe because the top bit is now zero.
    u64 h = (x >> (u64)1) & (u64)9223372036854775807;
    return h >> (u64)(n - 1);
}

// Unsigned a < b.
bool __fmt_ult(u64 a, u64 b) {
    i64 sa = (i64)(a ^ (u64)9223372036854775808);
    i64 sb = (i64)(b ^ (u64)9223372036854775808);
    return sa < sb;
}

// Unsigned x / 10. floor(x/10) == floor((x >> 1) / 5) and (x >> 1) always
// fits in a non-negative i64, so signed division is safe.
u64 __fmt_udiv10(u64 x) {
    u64 half = __fmt_lshr(x, 1);
    return (u64)((i64)half / 5);
}

// Count leading zeros of a nonzero u64 (returns 64 for 0).
i64 __fmt_clz64(u64 x) {
    if (x == (u64)0) {
        return 64;
    }
    i64 n = 0;
    while ((x & (u64)9223372036854775808) == (u64)0) {
        x = x << (u64)1;
        n = n + 1;
    }
    return n;
}

// 10^i as u64 for i in [0, 19]; 0 for i >= 20 (mirrors the rapidjson guard).
u64 __fmt_pow10(i64 i) {
    if (i <= 0) { return (u64)1; }
    if (i == 1) { return (u64)10; }
    if (i == 2) { return (u64)100; }
    if (i == 3) { return (u64)1000; }
    if (i == 4) { return (u64)10000; }
    if (i == 5) { return (u64)100000; }
    if (i == 6) { return (u64)1000000; }
    if (i == 7) { return (u64)10000000; }
    if (i == 8) { return (u64)100000000; }
    if (i == 9) { return (u64)1000000000; }
    if (i == 10) { return (u64)10000000000; }
    if (i == 11) { return (u64)100000000000; }
    if (i == 12) { return (u64)1000000000000; }
    if (i == 13) { return (u64)10000000000000; }
    if (i == 14) { return (u64)100000000000000; }
    if (i == 15) { return (u64)1000000000000000; }
    if (i == 16) { return (u64)10000000000000000; }
    if (i == 17) { return (u64)100000000000000000; }
    if (i == 18) { return (u64)1000000000000000000; }
    if (i == 19) { return (u64)10000000000000000000; }
    return (u64)0;
}

// ---------------------------------------------------------------------------
// Integer / bool formatting (a).
// All formatters write into a caller-provided buffer and return the length.
// Buffer requirements: itoa <= 20 bytes, utoa <= 20 bytes, btoa <= 5 bytes.
// ---------------------------------------------------------------------------

pub i64 utoa(u64 v, u8* buf) {
    if (v == (u64)0) {
        buf[0] = (u8)48; // '0'
        return 1;
    }
    i64 n = 0;
    while (v != (u64)0) {
        u64 q = __fmt_udiv10(v);
        i64 digit = (i64)(v - q * (u64)10);
        buf[n] = (u8)(48 + digit);
        n = n + 1;
        v = q;
    }
    // Digits were produced least-significant first; reverse in place.
    i64 lo = 0;
    i64 hi = n - 1;
    while (lo < hi) {
        u8 t = buf[lo];
        buf[lo] = buf[hi];
        buf[hi] = t;
        lo = lo + 1;
        hi = hi - 1;
    }
    return n;
}

pub i64 itoa(i64 v, u8* buf) {
    if (v < 0) {
        buf[0] = (u8)45; // '-'
        // Two's-complement negation in u64 handles i64::MIN correctly.
        u64 mag = (u64)0 - (u64)v;
        return 1 + utoa(mag, &buf[1]);
    }
    return utoa((u64)v, buf);
}

pub i64 btoa(bool v, u8* buf) {
    if (v) {
        buf[0] = (u8)116; // 't'
        buf[1] = (u8)114; // 'r'
        buf[2] = (u8)117; // 'u'
        buf[3] = (u8)101; // 'e'
        return 4;
    }
    buf[0] = (u8)102; // 'f'
    buf[1] = (u8)97;  // 'a'
    buf[2] = (u8)108; // 'l'
    buf[3] = (u8)115; // 's'
    buf[4] = (u8)101; // 'e'
    return 5;
}

// ---------------------------------------------------------------------------
// f64 formatting: Grisu2 core (ported from rapidjson internal/dtoa.h,diyfp.h).
// ---------------------------------------------------------------------------

struct FmtDiyFp {
    u64 f;
    i64 e;
}

