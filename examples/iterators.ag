import std.io;
import std.optional;
import std.iter;

struct Counter {
    i32 current;
    i32 end;
}

impl Counter {
    Counter new(i32 end) {
        Counter c;
        c.current = 0;
        c.end = end;
        return c;
    }
}

impl IntoIterator<Counter> for Counter {
    type Item = i32;
    type IntoIter = Counter;
    Counter into_iter(Counter self) {
        return self;
    }
}

impl Iterator<Counter> for Counter {
    type Item = i32;
    Optional<i32> next(Counter* self) {
        if ((*self).current < (*self).end) {
            Optional<i32> result = Optional<i32>.some((*self).current);
            (*self).current = (*self).current + 1;
            return result;
        }
        return Optional<i32>.none();
    }
}

i32 main() {
    Counter c = Counter.new(5);
    for i in c {
        printf("counter: %d\n", i);
    }

    printf("sum 0..9 = ");
    i32 total = 0;
    for i in 0..10 {
        total = total + i;
    }
    printf("%d\n", total);

    return 0;
}
