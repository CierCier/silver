import std.io;

trait HasHandler {
    handler: (i32) -> i32;
}

struct Doubler {}
struct Tripler {}

impl HasHandler for Doubler {
    i32 handler(i32 x) {
        return x * 2;
    }
}

impl HasHandler for Tripler {
    i32 handler(i32 x) {
        return x * 3;
    }
}

i32 main() {
    @println("Doubler::handler(7) = {}", Doubler.handler(7));
    @println("Tripler::handler(7) = {}", Tripler.handler(7));
    return 0;
}
