import std.io;

i32 fibonacci(i32 n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

i32 main() {
    printf("=== Fibonacci ===\n");
    i32 n = 10;
    i32 result = fibonacci(n);
    printf("fib(%d) = %d\n", n, result);

    printf("\n=== Type sizes ===\n");
    printf("size of i32: %d bytes\n", @size(i32));
    printf("size of f64: %d bytes\n", @size(f64));
    printf("size of Point: %d bytes\n", @size(Point));

    return 0;
}

struct Point {
    f64 x;
    f64 y;
}
