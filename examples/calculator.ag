import std.io;
import std.math;

i32 main() {
    printf("=== Simple Calculator ===\n");
    printf("Enter: a op b\n");
    printf("Type 'q' to quit\n\n");

    i32 running = 1;
    while (running != 0) {
        printf("> ");

        f64 a = 0.0;
        char op = (char)0;
        f64 b = 0.0;

        i32 result = scanf(" %lf %c %lf", &a, &op, &b);
        if (result == 3) {
            f64 answer = 0.0;
            if (op == '+') {
                answer = a + b;
            } else {
                if (op == '-') {
                    answer = a - b;
                } else {
                    if (op == '*') {
                        answer = a * b;
                    } else {
                        if (op == '/') {
                            if (b == 0.0) {
                                printf("Error: division by zero\n");
                                i32 ch = getchar();
                                while (ch != 10 && ch != -1) {
                                    ch = getchar();
                                }
                                continue;
                            }
                            answer = a / b;
                        } else {
                            if (op == '^') {
                                answer = pow(a, b);
                            } else {
                                printf("Unknown operator\n");
                                i32 ch = getchar();
                                while (ch != 10 && ch != -1) {
                                    ch = getchar();
                                }
                                continue;
                            }
                        }
                    }
                }
            }
            printf("= %.4f\n", answer);
        } else {
            char cmd = (char)0;
            scanf(" %c", &cmd);
            if (cmd == 'q' || cmd == 'Q') {
                running = 0;
            } else {
                printf("Invalid input\n");
            }
            i32 ch = getchar();
            while (ch != 10 && ch != -1) {
                ch = getchar();
            }
        }
    }

    printf("Goodbye!\n");
    return 0;
}
