import std.io;
import std.optional;


struct Dim<T> {
    T x;
    T y;
    Optional<T> z; // Optional third dimension
}

impl Dim<T> {
    Dim<T> new(T x, T y) {
        Dim<T> d = { .x = x, .y = y, .z = Optional<T>.none() };
        return d;
    }

    i32 set_z(Dim<T>* self, T value) {
        self.z = Optional<T>.some(value);
        return 0;
    }

    i32 has_z(Dim<T> self) {
        if (self.z.is_some()) {
            return 1;
        }
        return 0;
    }
}

i32 main(){
    Dim<i32> d = Dim<i32>.new(10, 20);

    printf("Dim: x=%d, y=%d\n", d.x, d.y);
    if (d.has_z()) {
        printf("z is present: %d\n", d.z.unwrap());
    } else {
        printf("z is not present\n");
    }

    d.set_z(30);

    if (d.has_z()) {
        printf("z is now present: %d\n", d.z.unwrap());
    } else {
        printf("z is still not present\n");
    }

    return 0;
}
