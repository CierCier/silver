import std.io;
import std.math;

struct Point {
    f64 x;
    f64 y;
}

impl Point {
    cast f64(Point self) {
		f64 x_2 = self.x * self.x;
		f64 y_2 = self.y * self.y;

        return sqrt(x_2 + y_2);
    }
}

i32 main() {
    i32 x = 10;
    f64 y = (f64) x;
    printf("x as f64: %f\n", y);

    f64 z = 3.14;
    i32 w = (i32) z;
    printf("z as i32: %d\n", w);

    Point p = { .x = 2.0, .y = 1.0 };

    f64 magnitude = (f64) p;

    printf("Magnitude of Point p: %f\n", magnitude);

    return 0;
}
