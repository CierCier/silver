import std.io;
import std.math;

struct Point {
    f64 x;
    f64 y;
}

impl Point {
    cast f64(Point self) {
        return sqrt(self.x * self.x + self.y * self.y);
    }
}

i32 main() {
    i32 x = 42;
    f64 y = (f64)x;
    @println("i32 {} as f64: {}", x, y);

    f64 z = 3.14159;
    i32 w = (i32)z;
    @println("f64 {} as i32: {}", z, w);

    Point p = { .x = 3.0, .y = 4.0 };
    f64 mag = (f64)p;
    @println("Point(3,4) magnitude: {}", mag);

    return 0;
}
