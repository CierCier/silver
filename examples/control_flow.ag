import std.io;

i32 factorial(i32 n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

i32 sum_while(i32 limit) {
    i32 sum = 0;
    i32 i = 0;
    while (i < limit) {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

i32 skip_threes(i32 limit) {
    i32 sum = 0;
    i32 i = 0;
    while (i < limit) {
        i = i + 1;
        if (i % 3 == 0) {
            continue;
        }
        sum = sum + i;
        if (sum > 100) {
            break;
        }
    }
    return sum;
}

i32 main() {
    printf("factorial(5) = %d\n", factorial(5));
    printf("sum 0..9 = %d\n", sum_while(10));
    printf("skip_threes(50) = %d\n", skip_threes(50));

    for i in 0..5 {
        printf("for-in: %d\n", i);
    }

    i32 z = 40;
    i32* p = &z;
    *p = 50;
    printf("z via pointer: %d\n", z);

    return 0;
}
