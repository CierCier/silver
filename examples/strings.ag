import std.io;
import std.string;

i32 main() {
    String greeting = String.new();
    greeting.push_str("Hello");
    greeting.push((u8)32);       // space
    greeting.push_str("Silver");
    greeting.push((u8)33);       // '!'
    @println("greeting: {}", greeting.to_str());
    @println("length: {}", greeting.len());

    // clone borrows greeting (by pointer), creates a deep copy
    String clone = greeting.clone();
    @println("clone: {}", clone.to_str());

    // Show that modifying greeting does not affect clone
    greeting.push_str("!!");
    @println("after append: {}", greeting.to_str());
    @println("clone unchanged: {}", clone.to_str());

    // Show that modifying clone does not affect greeting
    clone.clear();
    @println("after clear, len={}", clone.len());
    @println("greeting still intact: {}", greeting.to_str());
    // equals takes a C string — compare clone against "HelloSilver!"
    if (greeting.equals("HelloSilver!!")) {
        @println("greeting equals 'HelloSilver!!': true");
    } else {
        @println("greeting equals 'HelloSilver!!': false");
    }

    // Build a string with a loop
    String built = String.new();
    for i in 0..5 {
        built.push((u8)(65 + i));  // A B C D E
    }
    built.push((u8)10);  // newline
    @print("built: {}", built.to_str());

    // No need for explicit drop calls — the compiler handles
    // implicit destructors via the flag system.
    return 0;
}
