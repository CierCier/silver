import std.io;

trait Area {
    fn area(Circle self) -> f64;
    fn kind(Circle self) -> str { return "shape"; }
}

struct Circle {
    f64 radius;
}

impl Area for Circle {
    f64 area(Circle self) {
        return 3.14159265 * self.radius * self.radius;
    }

    str kind(Circle self) {
        return "circle";
    }
}

i32 main() {
    Circle c = { .radius = 5.0 };

    printf("A %s has area %.2f\n", c.kind(), c.area());

    return 0;
}
