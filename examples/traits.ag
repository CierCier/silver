import std.io;
import std.math;

trait Area<Self> {
    f64 area(Self self);
    str kind(Self self) { return "shape"; }
}

struct Circle {
    f64 radius;
}

impl Area<Circle> for Circle {
    f64 area(Circle self) {
        return M_PI * self.radius * self.radius;
    }

    str kind(Circle self) {
        return "circle";
    }
}

i32 main() {
    Circle c = { .radius = 5.0 };
    printf("A %s has area %.2f\n", c.kind(), c.area());

    return 0;
}
