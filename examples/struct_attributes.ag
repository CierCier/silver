import std.io;

#[packed]
struct PackedPoint {
    i8 x;
    i32 y;
}

#[align(16)]
struct AlignedVec {
    f64 x;
    f64 y;
}

#[repr(C)]
struct CLike {
    i32 id;
    bool flag;
}

struct DefaultLayout {
    i8 a;
    i32 b;
    i8 c;
}

i32 main() {
    @println("PackedPoint size: {} bytes", @size(PackedPoint));
    @println("AlignedVec size: {} bytes", @size(AlignedVec));
    @println("CLike size: {} bytes", @size(CLike));
    @println("DefaultLayout size: {} bytes", @size(DefaultLayout));

    PackedPoint p = { .x = 10, .y = 99 };
    AlignedVec v = { .x = 1.0, .y = 2.0 };
    CLike c = { .id = 42, .flag = true };

    @println("p: ({}, {})", p.x, p.y);
    @println("v: ({}, {})", v.x, v.y);
    @println("c: id={} flag={}", c.id, c.flag);

    return 0;
}
