import std.io;

#[packed]
struct PackedPoint {
    i8 x;
    i32 y;
}

#[align(16)]
struct AlignedVec {
    f64 x;
    f64 y;
}

#[repr(C)]
struct CLike {
    i32 id;
    bool flag;
}

struct DefaultLayout {
    i8 a;
    i32 b;
    i8 c;
}

i32 main() {
    printf("PackedPoint size: %d bytes\n", @size(PackedPoint));
    printf("AlignedVec size: %d bytes\n", @size(AlignedVec));
    printf("CLike size: %d bytes\n", @size(CLike));
    printf("DefaultLayout size: %d bytes\n", @size(DefaultLayout));

    PackedPoint p = { .x = 10, .y = 99 };
    AlignedVec v = { .x = 1.0, .y = 2.0 };
    CLike c = { .id = 42, .flag = true };

    printf("p: (%d, %d)\n", p.x, p.y);
    printf("v: (%.1f, %.1f)\n", v.x, v.y);
    printf("c: id=%d flag=%d\n", c.id, c.flag);

    return 0;
}
