// ownership.ag -- Ownership transfer with `move`
//
// Variables own their value. When a variable goes out of scope its
// implicit destructor (`drop`) runs automatically.  The `move` keyword
// transfers ownership: the source variable is left in an "already
// dropped" state so only the destination cleans up.
//
// This prevents double-free without garbage collection.

import std.io;
import std.mem;

// A resource that logs every construction and destruction.
i32 live_count = 0;

struct Buffer {
    i32* data;
    i32 length;
}

impl Buffer {
    void init(Buffer* self, i32 len) {
        self.data = alloc<i32>(len);
        self.length = len;
        live_count = live_count + 1;
        @println("  [create] Buffer(len={})  live={}", len, live_count);
    }

    void drop(Buffer* self) {
        if (self.data != (i32*)0) {
            free(self.data);
            self.data = (i32*)0;
        }
        live_count = live_count - 1;
        @println("  [destroy] Buffer(len={})  live={}",
               self.length, live_count);
    }
}

i32 main() {
    @println("=== Ownership: scope-based teardown ===");
    {
        Buffer b;
        b.init(16);
        @println("  using buffer...");
    }
    @println("  (after scope) live={}\n", live_count);

    @println("=== Transfer: move prevents double-free ===");
    {
        Buffer a;
        a.init(32);

        // `move a` transfers ownership to `b`.
        // `a`'s drop flag is cleared -- the destructor for `a`
        // will NOT run, only `b`'s drops when this scope exits.
        Buffer b = move a;
        @println("  moved a -> b  (b.len={})", b.length);

        // At scope exit, only `b` is destroyed.  Without `move`,
        // both `a` and `b` would call `free()` on the same pointer.
    }
    @println("  (after move scope) live={}\n", live_count);

    // Without move, a copy would alias the same pointer and both
    // destructors would fire.  `move` makes the intent explicit.
    @println("=== Default: without move, destructor runs ===");
    {
        Buffer x;
        x.init(8);
        @println("  x.len={}", x.length);
        // x.drop() runs at scope end
    }
    @println("  live={}\n", live_count);

    @println("All OK");
    return 0;
}
