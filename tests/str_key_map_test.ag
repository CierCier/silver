import std.io;
import std.map;

i32 tests_passed = 0;
i32 tests_failed = 0;

void assert_true(bool cond, str msg) {
    if (cond) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s\n", msg);
    }
}

void assert_eq_i64(i64 a, i64 b, str msg) {
    if (a == b) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s (expected %ld, got %ld)\n", msg, b, a);
    }
}

void assert_eq_str(str a, str b, str msg) {
    if (a == b) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s (expected \"%s\", got \"%s\")\n", msg, b, a);
    }
}

i32 main() {
    printf("=== HashMap<str, i64> Tests ===\n\n");

    // --- Basic insert/get with str keys ---
    printf("--- Basic str keys ---\n");
    HashMap<str, i64> m = HashMap<str, i64>.new();
    assert_true(m.is_empty(), "new map is empty");

    m.insert("one", 10);
    m.insert("two", 20);
    m.insert("three", 30);
    assert_eq_i64(m.len(), 3, "len=3 after 3 inserts");

    assert_true(m.contains_key("one"), "contains key 'one'");
    assert_true(m.contains_key("two"), "contains key 'two'");
    assert_true(m.contains_key("three"), "contains key 'three'");
    assert_true(!m.contains_key("four"), "does NOT contain key 'four'");

    assert_eq_i64(m.get("one"), 10, "get('one') == 10");
    assert_eq_i64(m.get("two"), 20, "get('two') == 20");
    assert_eq_i64(m.get("three"), 30, "get('three') == 30");

    m.drop();

    // --- str keys with same content from different pointer sources ---
    printf("\n--- Same content, different sources ---\n");
    HashMap<str, i64> m2 = HashMap<str, i64>.new();
    str a = "hello";
    str b = "hello";  // same literal, likely same ptr
    m2.insert(a, 100);
    assert_true(m2.contains_key(b), "contains 'hello' via b when inserted via a");
    assert_eq_i64(m2.get(a), 100, "get(a) == 100");
    assert_eq_i64(m2.get(b), 100, "get(b) == 100 (same content, possibly different ptr)");
    m2.drop();

    // --- Erase str keys ---
    printf("\n--- Erase str keys ---\n");
    HashMap<str, i64> m3 = HashMap<str, i64>.new();
    m3.insert("alpha", 1);
    m3.insert("beta", 2);
    m3.insert("gamma", 3);
    assert_eq_i64(m3.len(), 3, "len=3 before erase");

    assert_true(m3.erase("beta"), "erase('beta') returns true");
    assert_eq_i64(m3.len(), 2, "len=2 after erase");
    assert_true(!m3.contains_key("beta"), "'beta' gone after erase");
    assert_true(m3.contains_key("alpha"), "'alpha' still present");
    assert_true(m3.contains_key("gamma"), "'gamma' still present");
    assert_eq_i64(m3.get("alpha"), 1, "get('alpha') still 1");
    assert_eq_i64(m3.get("gamma"), 3, "get('gamma') still 3");

    // Erase non-existent key
    assert_true(!m3.erase("delta"), "erase('delta') returns false for non-existent key");
    m3.drop();

    // --- Resize with str keys ---
    printf("\n--- Resize with str keys ---\n");
    HashMap<str, i64> m4 = HashMap<str, i64>.new();
    // Insert more than INITIAL_CAPACITY * LOAD_FACTOR to trigger grow
    m4.insert("k0", 0);
    m4.insert("k1", 10);
    m4.insert("k2", 20);
    m4.insert("k3", 30);
    m4.insert("k4", 40);
    m4.insert("k5", 50);
    m4.insert("k6", 60);
    m4.insert("k7", 70);
    m4.insert("k8", 80);
    m4.insert("k9", 90);
    m4.insert("k10", 100);
    m4.insert("k11", 110);
    m4.insert("k12", 120);
    m4.insert("k13", 130);
    m4.insert("k14", 140);
    m4.insert("k15", 150);  // 16th insert should trigger grow from 16 to 32
    assert_eq_i64(m4.len(), 16, "len=16 after 16 inserts");

    // Verify all values after resize
    assert_eq_i64(m4.get("k0"), 0, "k0 intact after resize");
    assert_eq_i64(m4.get("k5"), 50, "k5 intact after resize");
    assert_eq_i64(m4.get("k10"), 100, "k10 intact after resize");
    assert_eq_i64(m4.get("k15"), 150, "k15 intact after resize");
    assert_eq_i64(m4.get("k7"), 70, "k7 intact after resize");
    m4.drop();

    // --- Indexed access with str keys ---
    printf("\n--- Indexed access ---\n");
    HashMap<str, i64> m5 = HashMap<str, i64>.new();
    m5["apple"] = 5;
    m5["banana"] = 7;
    m5["cherry"] = 9;
    assert_eq_i64(m5["apple"], 5, "m5['apple'] == 5 via index");
    assert_eq_i64(m5["banana"], 7, "m5['banana'] == 7 via index");
    assert_eq_i64(m5["cherry"], 9, "m5['cherry'] == 9 via index");

    // Overwrite via index
    m5["apple"] = 99;
    assert_eq_i64(m5["apple"], 99, "m5['apple'] overwritten to 99 via index");
    m5.drop();

    printf("\n=== Results: %d passed, %d failed ===\n", tests_passed, tests_failed);
    return tests_failed;
}
