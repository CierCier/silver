// Test suite for std.io - I/O operations
import std.test;
i32 main() {
    STDOUT.write_str("=== I/O Tests ===\n\n");

    // Test: write_str basic functionality
    STDOUT.write_str("--- write_str Tests ---\n");

    STDOUT.write_str("Test string\n");
    assert_true(true, "write_str works");
    tests_passed = tests_passed + 1;

    // Test: write_i64
    STDOUT.write_str("\n--- write_i64 Tests ---\n");
    STDOUT.write_str("Integer: ");
    STDOUT.write_i64(42);
    STDOUT.write_str("\n");
    assert_true(true, "write_i64 works");
    tests_passed = tests_passed + 1;

    STDOUT.write_str("Long: ");
    STDOUT.write_i64(9223372036854775807);
    STDOUT.write_str("\n");
    assert_true(true, "write_i64 with large value works");
    tests_passed = tests_passed + 1;

    // Test: write_f64
    STDOUT.write_str("\n--- write_f64 Tests ---\n");
    STDOUT.write_str("Float: ");
    STDOUT.write_f64(3.14159);
    STDOUT.write_str("\n");
    assert_true(true, "write_f64 works");
    tests_passed = tests_passed + 1;

    // Test: write_str with string
    str str_val = "hello";
    STDOUT.write_str("String: ");
    STDOUT.write_str(str_val);
    STDOUT.write_str("\n");
    assert_true(true, "write_str works");
    tests_passed = tests_passed + 1;

    // Test: write_u64
    STDOUT.write_str("Hex: 255 = ");
    STDOUT.write_u64(255);
    STDOUT.write_str("\n");
    assert_true(true, "write_u64 works");
    tests_passed = tests_passed + 1;

    // Test: write_bool
    STDOUT.write_str("bool true = ");
    STDOUT.write_bool(true);
    STDOUT.write_str(", bool false = ");
    STDOUT.write_bool(false);
    STDOUT.write_str("\n");
    assert_true(true, "write_bool works");
    tests_passed = tests_passed + 1;

    // Test: println wrapper
    STDOUT.write_str("\n--- println Tests ---\n");

    i32 pret = println("Line from println");
    assert_true(pret > 0, "println returns positive value");

    // Test: Multiple write_str calls
    STDOUT.write_str("\n--- Multiple write_str ---\n");

    STDOUT.write_str("Three values: ");
    STDOUT.write_i64(1);
    STDOUT.write_str(", ");
    STDOUT.write_i64(2);
    STDOUT.write_str(", ");
    STDOUT.write_i64(3);
    STDOUT.write_str("\n");
    assert_true(true, "multiple write_i64 calls work");
    tests_passed = tests_passed + 1;

    // Test: Escape sequences
    STDOUT.write_str("\n--- Escape Sequences ---\n");

    STDOUT.write_str("Tab:\tafter tab\n");
    STDOUT.write_str("Quote: \"quoted\"\n");
    STDOUT.write_str("Backslash: \\\n");
    assert_true(true, "escape sequences work");
    tests_passed = tests_passed + 1;

    // Test: Empty string
    STDOUT.write_str("\n--- Edge Cases ---\n");

    STDOUT.write_str("");


    // Test: eprintln
    STDOUT.write_str("\n--- eprintln Tests ---\n");
    eprintln("stderr message via eprintln");
    assert_true(true, "eprintln works");
    tests_passed = tests_passed + 1;

    // Summary
    return done();
}
