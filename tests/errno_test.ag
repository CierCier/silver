// Test suite for the typed syscall/errno layer:
// std/sys/errno.ag (errno constants, errno_name) and
// std/sys/result.ag (SysResult + try_* syscall front-ends).
import std.io;
import std.mem;
import std.sys.errno;
import std.sys.result;

i32 tests_passed = 0;
i32 tests_failed = 0;

void assert_true(bool cond, str msg) {
    if (cond) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s\n", msg);
    }
}

void assert_eq_i64(i64 a, i64 b, str msg) {
    if (a == b) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s (expected %ld, got %ld)\n", msg, b, a);
    }
}

void assert_str_eq(str a, str b, str msg) {
    if (a == b) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s (expected %s, got %s)\n", msg, b, a);
    }
}

i32 main() {
    printf("=== errno / SysResult Tests ===\n\n");

    // --- errno constants and errno_name ---
    printf("--- errno_name ---\n");
    {
        assert_eq_i64(EPERM, 1, "EPERM == 1");
        assert_eq_i64(EBADF, 9, "EBADF == 9");
        assert_eq_i64(ERANGE, 34, "ERANGE == 34");
        assert_eq_i64(ENOSYS, 38, "ENOSYS == 38");
        assert_eq_i64(ETIMEDOUT, 110, "ETIMEDOUT == 110");
        assert_str_eq(errno_name(EPERM), "EPERM", "errno_name(EPERM)");
        assert_str_eq(errno_name(EAGAIN), "EAGAIN", "errno_name(EAGAIN)");
        assert_str_eq(errno_name(ERANGE), "ERANGE", "errno_name(ERANGE)");
        assert_str_eq(errno_name(ENOSYS), "ENOSYS", "errno_name(ENOSYS)");
        assert_str_eq(errno_name(ETIMEDOUT), "ETIMEDOUT", "errno_name(ETIMEDOUT)");
        assert_str_eq(errno_name(-2), "ENOENT", "errno_name normalizes raw negative returns");
        assert_str_eq(errno_name(0), "EOK", "errno_name(0) == EOK");
        assert_str_eq(errno_name(9999), "EUNKNOWN", "errno_name of unknown value");
    }

    // --- raw return classification ---
    printf("\n--- is_errno / errno_of ---\n");
    {
        assert_true(is_errno(-1), "is_errno(-1)");
        assert_true(is_errno(-4095), "is_errno(-4095)");
        assert_true(!is_errno(-4096), "!is_errno(-4096)");
        assert_true(!is_errno(0), "!is_errno(0)");
        assert_true(!is_errno(42), "!is_errno(42)");
        assert_eq_i64(errno_of(-9), EBADF, "errno_of(-9) == EBADF");
        assert_eq_i64(errno_of(17), 0, "errno_of(success) == 0");
    }

    // --- SysResult decoding ---
    printf("\n--- SysResult.from_raw ---\n");
    {
        SysResult ok = SysResult.from_raw(7);
        assert_true(ok.is_ok(), "from_raw(7) is ok");
        assert_true(!ok.is_err(), "from_raw(7) not err");
        assert_eq_i64(ok.value, 7, "from_raw(7) value");
        assert_eq_i64(ok.errno, 0, "from_raw(7) errno 0");
        assert_eq_i64(ok.unwrap_or(-1), 7, "unwrap_or on ok returns value");

        SysResult err = SysResult.from_raw(-22);
        assert_true(err.is_err(), "from_raw(-22) is err");
        assert_eq_i64(err.errno, EINVAL, "from_raw(-22) errno == EINVAL");
        assert_eq_i64(err.value, 0, "from_raw(-22) value zeroed");
        assert_true(err.err_is(EINVAL), "err_is(EINVAL)");
        assert_true(!err.err_is(EBADF), "!err_is(EBADF)");
        assert_eq_i64(err.unwrap_or(-1), -1, "unwrap_or on err returns fallback");
        assert_str_eq(err.err_name(), "EINVAL", "err_name on failure");

        // A large positive return (e.g. a mmap address) must not be an error.
        SysResult addr = SysResult.from_raw(140000000000000);
        assert_true(addr.is_ok(), "large positive raw value is ok");
    }

    // --- write success path (fd 1) ---
    printf("\n--- try_write ---\n");
    {
        str msg = "  [info] hello from try_write\n";
        SysResult w = try_write(STDOUT_FD, (u8*)msg, 30);
        assert_true(w.is_ok(), "write to stdout succeeds");
        assert_eq_i64(w.value, 30, "write returns byte count");
        assert_str_eq(w.err_name(), "EOK", "err_name on success is EOK");
    }

    // --- getpid success path ---
    printf("\n--- try_getpid ---\n");
    {
        SysResult pid = try_getpid();
        assert_true(pid.is_ok(), "getpid succeeds");
        assert_true(pid.value > 0, "pid is positive");
        SysResult pid2 = try_getpid();
        assert_eq_i64(pid2.value, pid.value, "getpid is stable");

        // kill(pid, 0) probes existence without sending a signal.
        SysResult k = try_kill((i32)pid.value, 0);
        assert_true(k.is_ok(), "kill(self, 0) succeeds");
    }

    // --- mmap / mremap / munmap success paths ---
    printf("\n--- try_mmap / try_mremap / try_munmap ---\n");
    {
        SysResult m = try_mmap((void*)0, 4096, PROT_READ | PROT_WRITE,
                               MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
        assert_true(m.is_ok(), "anonymous mmap of one page succeeds");
        assert_true(m.value != 0, "mmap returns non-null address");
        assert_eq_i64(m.value % 4096, 0, "mmap address is page-aligned");

        // The mapping must be readable and writable.
        u8* page = (u8*)m.value;
        page[0] = (u8)65;
        page[4095] = (u8)90;
        assert_true(page[0] == (u8)65, "first byte of mapping writable");
        assert_true(page[4095] == (u8)90, "last byte of mapping writable");

        // Grow the mapping to two pages (may move).
        SysResult grown = try_mremap((void*)m.value, 4096, 8192, MREMAP_MAYMOVE);
        assert_true(grown.is_ok(), "mremap to two pages succeeds");
        u8* big = (u8*)grown.value;
        assert_true(big[0] == (u8)65, "contents preserved across mremap");
        big[8191] = (u8)33;
        assert_true(big[8191] == (u8)33, "grown region writable");

        SysResult um = try_munmap((void*)grown.value, 8192);
        assert_true(um.is_ok(), "munmap succeeds");
        assert_eq_i64(um.value, 0, "munmap returns 0");
    }

    // --- open / read / lseek / close on /dev/null and /dev/zero ---
    printf("\n--- try_open / try_read / try_lseek / try_close ---\n");
    {
        SysResult o = try_open("/dev/null", O_RDONLY, 0);
        assert_true(o.is_ok(), "open /dev/null succeeds");
        assert_true(o.value >= 0, "open returns a valid fd");
        i32 fd = (i32)o.value;

        u8* buffer = alloc<u8>(16);
        SysResult r = try_read(fd, buffer, 16);
        assert_true(r.is_ok(), "read from /dev/null succeeds");
        assert_eq_i64(r.value, 0, "read from /dev/null returns EOF (0)");
        free(buffer);

        SysResult s = try_lseek(fd, 0, SEEK_SET);
        assert_true(s.is_ok(), "lseek on /dev/null succeeds");

        SysResult c = try_close(fd);
        assert_true(c.is_ok(), "close succeeds");
        assert_eq_i64(c.value, 0, "close returns 0");

        SysResult oat = try_openat((i32)AT_FDCWD, "/dev/zero", O_RDONLY, 0);
        assert_true(oat.is_ok(), "openat(AT_FDCWD, /dev/zero) succeeds");
        i32 zfd = (i32)oat.value;
        u8* zbuf = alloc<u8>(8);
        zbuf[0] = (u8)255;
        SysResult zr = try_read(zfd, zbuf, 8);
        assert_true(zr.is_ok(), "read from /dev/zero succeeds");
        assert_eq_i64(zr.value, 8, "read from /dev/zero returns 8 bytes");
        assert_true(zbuf[0] == (u8)0, "/dev/zero reads zeroes");
        free(zbuf);
        try_close(zfd);
    }

    // --- failure paths ---
    printf("\n--- failure paths ---\n");
    {
        // close(-1) -> EBADF
        SysResult c = try_close(-1);
        assert_true(c.is_err(), "close(-1) fails");
        assert_eq_i64(c.errno, EBADF, "close(-1) errno == EBADF");
        assert_str_eq(c.err_name(), "EBADF", "close(-1) err_name == EBADF");

        // read on a bad fd -> EBADF
        u8* buffer = alloc<u8>(4);
        SysResult r = try_read(-1, buffer, 4);
        assert_true(r.is_err(), "read on bad fd fails");
        assert_eq_i64(r.errno, EBADF, "read on bad fd errno == EBADF");
        free(buffer);

        // write on a bad fd -> EBADF
        str msg = "x";
        SysResult w = try_write(-1, (u8*)msg, 1);
        assert_true(w.err_is(EBADF), "write on bad fd errno == EBADF");

        // open of a missing path -> ENOENT
        SysResult o = try_open("/nonexistent/silver/errno/test/path", O_RDONLY, 0);
        assert_true(o.is_err(), "open of missing path fails");
        assert_eq_i64(o.errno, ENOENT, "open of missing path errno == ENOENT");

        // openat with a bad dirfd and relative path -> EBADF
        SysResult oat = try_openat(-1, "relative_path_that_does_not_exist", O_RDONLY, 0);
        assert_true(oat.err_is(EBADF), "openat with bad dirfd errno == EBADF");

        // lseek on a bad fd -> EBADF
        SysResult s = try_lseek(-1, 0, SEEK_SET);
        assert_true(s.err_is(EBADF), "lseek on bad fd errno == EBADF");

        // mmap with neither MAP_PRIVATE nor MAP_SHARED -> EINVAL
        SysResult m = try_mmap((void*)0, 4096, PROT_READ, MAP_ANONYMOUS, -1, 0);
        assert_true(m.is_err(), "mmap without sharing flags fails");
        assert_eq_i64(m.errno, EINVAL, "mmap without sharing flags errno == EINVAL");

        // munmap with an unaligned address -> EINVAL
        SysResult um = try_munmap((void*)4097, 4096);
        assert_true(um.err_is(EINVAL), "munmap of unaligned address errno == EINVAL");

        // mremap with an unaligned old address -> EINVAL
        SysResult mr = try_mremap((void*)4097, 4096, 8192, MREMAP_MAYMOVE);
        assert_true(mr.err_is(EINVAL), "mremap of unaligned address errno == EINVAL");

        // kill of an out-of-range pid -> ESRCH
        SysResult k = try_kill(999999999, 0);
        assert_true(k.err_is(ESRCH), "kill of nonexistent pid errno == ESRCH");
    }

    printf("\nTests passed: %d, failed: %d\n", tests_passed, tests_failed);

    // Exercise exit_group's success path for real: flush stdio, then exit
    // with the failure count as the status (0 == all passed).
    fflush(stdout);
    exit_group((i64)tests_failed);
    return tests_failed;
}
