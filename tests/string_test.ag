// Test suite for std.string - String type
import std.test;  // assert_true, assert_false, assert_eq_i64, assert_eq_i32, done, STDOUT
import std.string;

i32 main(){
    String s = String.new();
    assert_eq_i64(s.len, 0, "New string has length 0");
    assert_eq_i64(s.capacity, 16, "New string has initial capacity 16");
    assert_true(s.data != (u8*)0, "New string has non-null data pointer");
    s.drop();

    String s1 = String.with_capacity(32);
    assert_eq_i64(s1.len, 0, "String with_capacity has length 0");
    assert_eq_i64(s1.capacity, 32, "String with_capacity has specified capacity 32");
    assert_true(s1.data != (u8*)0, "String with_capacity has non-null data pointer");
    s1.drop();

    // Test push
    String s2 = String.new();
    s2.push((u8)97); // 'a'
    s2.push((u8)98); // 'b'
    assert_eq_i64(s2.len(), 2, "Length is 2 after two pushes via len() method");
    assert_eq_i32((i32)s2.data[0], 97, "First char is 'a'");
    assert_eq_i32((i32)s2.data[1], 98, "Second char is 'b'");
    assert_eq_i32((i32)s2.data[2], 0, "Null terminator is correct");

    // Test push_str
    s2.push_str("cde");
    assert_eq_i64(s2.len(), 5, "Length is 5 after push_str");
    assert_eq_i32((i32)s2.data[2], 99, "Third char is 'c'");
    assert_eq_i32((i32)s2.data[3], 100, "Fourth char is 'd'");
    assert_eq_i32((i32)s2.data[4], 101, "Fifth char is 'e'");
    assert_eq_i32((i32)s2.data[5], 0, "Null terminator is correct after push_str");

    // Test clone and equals
    String s3 = s2.clone();
    assert_eq_i64(s3.len(), s2.len(), "Cloned string has same length");
    assert_true(s2.equals("abcde"), "String equals literal");
    
    // Modify original and check equality
    s2.push((u8)102); // 'f'
    assert_false(s2.equals("abcde"), "Modified string no longer equals old literal");
    assert_true(s2.equals("abcdef"), "Modified string equals updated literal");
    
    // Test to_str
    STDOUT.write_str("to_str: \"");
    STDOUT.write_str((str)s3.to_str());
    STDOUT.write_str("\"\n");
    check(true, "to_str runs without crashing");

    // Test clear
    s3.clear();
    assert_eq_i64(s3.len(), 0, "Length is 0 after clear");
    
    s2.drop();
    s3.drop();

    return done();
}
