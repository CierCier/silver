// Test suite for std.mem - Memory operations
import std.test;  // assert_true, assert_eq_i64, assert_eq_i32, check, done, STDOUT
import std.mem;

struct Point {
    i32 x;
    i32 y;
}

i32 main() {
    STDOUT.write_str("=== Memory Tests ===\n\n");
    
    // Test: alloc and free for primitives
    STDOUT.write_str("--- Primitive Allocation ---\n");
    
    i32* single_int = alloc<i32>();
    *single_int = 42;
    assert_eq_i32(*single_int, 42, "allocated memory is writable/readable");
    
    free(single_int);
    check(true, "free() completes without crash");
    
    // Test: Array allocation
    STDOUT.write_str("\n--- Array Allocation ---\n");
    
    i32* int_array = alloc<i32>(10);
    
    for (i32 i = 0; i < 10; i = i + 1) {
        int_array[i] = i * 10;
    }
    
    bool array_correct = true;
    for (i32 i = 0; i < 10; i = i + 1) {
        if (int_array[i] != i * 10) {
            array_correct = false;
        }
    }
    assert_true(array_correct, "array allocation allows indexed access");
    
    free(int_array);
    
    // Test: Struct allocation
    STDOUT.write_str("\n--- Struct Allocation ---\n");
    
    Point* single_point = alloc<Point>();
    
    single_point.x = 100;
    single_point.y = 200;
    assert_eq_i32(single_point.x, 100, "struct field x writable");
    assert_eq_i32(single_point.y, 200, "struct field y writable");
    
    free(single_point);
    
    // Test: Struct array allocation
    STDOUT.write_str("\n--- Struct Array Allocation ---\n");
    
    Point* points = alloc<Point>(5);
    
    for (i32 i = 0; i < 5; i = i + 1) {
        points[i].x = i;
        points[i].y = i * 2;
    }
    
    bool points_correct = true;
    for (i32 i = 0; i < 5; i = i + 1) {
        if (points[i].x != i || points[i].y != i * 2) {
            points_correct = false;
        }
    }
    assert_true(points_correct, "struct array allocation works correctly");
    
    free(points);
    
    // Test: memset
    STDOUT.write_str("\n--- memset ---\n");
    
    i8* buffer = alloc<i8>(100);
    memset(buffer, 0, 100);
    
    bool all_zero = true;
    for (i32 i = 0; i < 100; i = i + 1) {
        if (buffer[i] != 0) {
            all_zero = false;
        }
    }
    assert_true(all_zero, "memset sets all bytes to 0");
    
    memset(buffer, 65, 10);  // 'A' = 65
    assert_true(buffer[0] == 65, "memset sets first byte");
    assert_true(buffer[9] == 65, "memset sets last byte in range");
    assert_true(buffer[10] == 0, "memset doesn't affect bytes outside range");
    
    free(buffer);
    
    // Test: memcpy
    STDOUT.write_str("\n--- memcpy ---\n");
    
    i8* src = alloc<i8>(20);
    i8* dst = alloc<i8>(20);
    
    for (i32 i = 0; i < 20; i = i + 1) {
        src[i] = (i8)(i + 65);  // 'A', 'B', 'C', ...
    }
    
    memcpy(dst, src, 20);
    
    bool copy_correct = true;
    for (i32 i = 0; i < 20; i = i + 1) {
        if (dst[i] != src[i]) {
            copy_correct = false;
        }
    }
    assert_true(copy_correct, "memcpy copies all bytes correctly");
    
    free(src);
    free(dst);
    
    // Test: memmove (with overlapping regions)
    STDOUT.write_str("\n--- memmove ---\n");
    
    i8* overlap_buf = alloc<i8>(20);
    for (i32 i = 0; i < 10; i = i + 1) {
        overlap_buf[i] = (i8)(i + 48);  // '0', '1', '2', ...
    }
    
    memmove(&overlap_buf[5], overlap_buf, 10);
    
    assert_true(overlap_buf[0] == 48, "memmove preserves start of source");
    assert_true(overlap_buf[4] == 52, "memmove preserves end of unchanged region");
    assert_true(overlap_buf[5] == 48, "memmove copies to new position");
    assert_true(overlap_buf[14] == 57, "memmove copies last byte correctly");
    
    free(overlap_buf);
    
    // Test: realloc
    STDOUT.write_str("\n--- realloc ---\n");
    
    i32* grow_buf = alloc<i32>(5);
    for (i32 i = 0; i < 5; i = i + 1) {
        grow_buf[i] = i * 100;
    }
    
    grow_buf = (i32*)(realloc(grow_buf, 10 * 4));
    
    bool realloc_preserved = true;
    for (i32 i = 0; i < 5; i = i + 1) {
        if (grow_buf[i] != i * 100) {
            realloc_preserved = false;
        }
    }
    assert_true(realloc_preserved, "realloc preserves original data");
    
    grow_buf[9] = 999;
    assert_eq_i32(grow_buf[9], 999, "realloc allows access to new space");
    
    free(grow_buf);
    
    // Test: Large allocation
    STDOUT.write_str("\n--- Large Allocation ---\n");
    
    i64 large_size = 1000000;
    i8* large_buf = alloc<i8>(large_size);
    
    large_buf[0] = 1;
    large_buf[large_size - 1] = 2;
    assert_true(large_buf[0] == 1, "first byte of large alloc writable");
    assert_true(large_buf[large_size - 1] == 2, "last byte of large alloc writable");
    
    free(large_buf);
    
    // Test: Multiple allocations
    STDOUT.write_str("\n--- Multiple Allocations ---\n");
    
    i32** ptrs = alloc<i32*>(10);
    for (i32 i = 0; i < 10; i = i + 1) {
        ptrs[i] = alloc<i32>(100);
        ptrs[i][0] = i;
    }
    
    bool multi_correct = true;
    for (i32 i = 0; i < 10; i = i + 1) {
        if (ptrs[i][0] != i) {
            multi_correct = false;
        }
    }
    assert_true(multi_correct, "multiple allocations don't interfere");
    
    for (i32 i = 0; i < 10; i = i + 1) {
        free(ptrs[i]);
    }
    free(ptrs);
    
    // Test: zeroed allocation (calloc path) with recycled blocks
    STDOUT.write_str("\n--- Zeroed Allocation ---\n");

    u8* dirty = alloc<u8>(256);
    memset(dirty, 170, 256);  // 0xAA pattern
    free(dirty);

    u8* zeroed = alloc<u8>(256);
    bool zero_ok = true;
    for (i32 i = 0; i < 256; i = i + 1) {
        if (zeroed[i] != (u8)0) {
            zero_ok = false;
        }
    }
    assert_true(zero_ok, "alloc<T>(count) returns zeroed memory even for recycled blocks");
    free(zeroed);

    u8* rt_zeroed = silver_rt_alloc_zeroed(512, 16);
    memset(rt_zeroed, 187, 512);
    silver_rt_dealloc(rt_zeroed, 512, 16);
    rt_zeroed = silver_rt_alloc_zeroed(512, 16);
    bool rt_zero_ok = true;
    for (i32 i = 0; i < 512; i = i + 1) {
        if (rt_zeroed[i] != (u8)0) {
            rt_zero_ok = false;
        }
    }
    assert_true(rt_zero_ok, "silver_rt_alloc_zeroed zeroes recycled blocks");
    silver_rt_dealloc(rt_zeroed, 512, 16);

    // Test: free-list exercise — many small allocs, free, then reuse
    STDOUT.write_str("\n--- Free-List Reuse ---\n");

    i64* old_addrs = alloc<i64>(100);
    u8** small_ptrs = alloc<u8*>(100);

    for (i32 i = 0; i < 100; i = i + 1) {
        small_ptrs[i] = alloc<u8>(48);
        small_ptrs[i][0] = (u8)i;
        small_ptrs[i][47] = (u8)(99 - i);
        old_addrs[i] = (i64)small_ptrs[i];
    }

    bool small_ok = true;
    for (i32 i = 0; i < 100; i = i + 1) {
        if (small_ptrs[i][0] != (u8)i || small_ptrs[i][47] != (u8)(99 - i)) {
            small_ok = false;
        }
    }
    assert_true(small_ok, "100 small allocations hold distinct data");

    for (i32 i = 0; i < 100; i = i + 1) {
        free(small_ptrs[i]);
    }

    i32 reused = 0;
    for (i32 i = 0; i < 100; i = i + 1) {
        small_ptrs[i] = alloc<u8>(48);
        i64 addr = (i64)small_ptrs[i];
        for (i32 j = 0; j < 100; j = j + 1) {
            if (old_addrs[j] == addr) {
                reused = reused + 1;
                old_addrs[j] = 0;
            }
        }
    }
    assert_eq_i32(reused, 100, "free-list recycles all 100 freed blocks");

    for (i32 i = 0; i < 100; i = i + 1) {
        free(small_ptrs[i]);
    }
    free(small_ptrs);
    free(old_addrs);

    // Test: huge allocation (> 1 MiB, dedicated mmap path)
    STDOUT.write_str("\n--- Huge Allocation (>1MB) ---\n");

    i64 huge_size = 2 * 1024 * 1024 + 123;
    u8* huge = alloc<u8>(huge_size);
    assert_true(huge != (u8*)0, "2MB+ allocation returned non-null");
    huge[0] = 11;
    huge[huge_size - 1] = 22;
    assert_true(huge[0] == 11, "first byte of huge alloc writable");
    assert_true(huge[huge_size - 1] == 22, "last byte of huge alloc writable");

    huge = realloc<u8>(huge, 3 * 1024 * 1024);
    assert_true(huge != (u8*)0, "realloc of huge block returned non-null");
    assert_true(huge[0] == 11, "realloc preserves huge head byte");
    assert_true(huge[huge_size - 1] == 22, "realloc preserves huge tail byte");
    free(huge);

    // Test: frozen silver_rt_* surface semantics
    STDOUT.write_str("\n--- silver_rt_* Frozen Surface ---\n");

    u8* dangling = silver_rt_alloc(0, 8);
    assert_true(dangling != (u8*)0, "silver_rt_alloc(0) returns non-null dangling pointer");
    silver_rt_dealloc(dangling, 0, 8);
    check(true, "size-0 dealloc is a no-op");

    silver_rt_dealloc((u8*)0, 64, 8);
    check(true, "null dealloc is a no-op");

    u8* rt_buf = silver_rt_alloc(100, 16);
    assert_true(rt_buf != (u8*)0, "silver_rt_alloc(100) returns non-null");
    assert_true(((i64)rt_buf % 16) == 0, "silver_rt_alloc respects 16-byte alignment");
    rt_buf[0] = 7;
    rt_buf[99] = 8;

    u8* rt_grown = silver_rt_realloc(rt_buf, 100, 10000, 16);
    assert_true(rt_grown != (u8*)0, "silver_rt_realloc grow returns non-null");
    assert_true(rt_grown[0] == 7 && rt_grown[99] == 8, "silver_rt_realloc preserves data");

    u8* rt_gone = silver_rt_realloc(rt_grown, 10000, 0, 16);
    assert_true(rt_gone != (u8*)0, "silver_rt_realloc(new_size=0) returns dangling non-null");

    u8* from_null = silver_rt_realloc((u8*)0, 0, 64, 16);
    assert_true(from_null != (u8*)0, "silver_rt_realloc(null) behaves like alloc");
    silver_rt_dealloc(from_null, 64, 16);

    u8* rt_ret = silver_rt_memset((u8*)0, (u8)1, 8);
    assert_true(rt_ret == (u8*)0, "silver_rt_memset tolerates null and returns dst");
    rt_ret = silver_rt_memcpy((u8*)0, (u8*)0, 8);
    assert_true(rt_ret == (u8*)0, "silver_rt_memcpy tolerates null and returns dst");
    rt_ret = silver_rt_memmove((u8*)0, (u8*)0, 8);
    assert_true(rt_ret == (u8*)0, "silver_rt_memmove tolerates null and returns dst");

    u8* mv = alloc<u8>(32);
    for (i32 i = 0; i < 16; i = i + 1) {
        mv[i + 8] = (u8)(i + 1);
    }
    u8* mv_ret = silver_rt_memmove(mv, &mv[8], 16);
    assert_true(mv_ret == mv, "silver_rt_memmove returns dst");
    assert_true(mv[0] == (u8)1 && mv[15] == (u8)16, "overlapping memmove (dst < src) copies correctly");
    free(mv);

    assert_eq_i64(silver_rt_strlen("hello"), 5, "silver_rt_strlen counts bytes");
    assert_eq_i64(silver_rt_strlen((const char*)0), 0, "silver_rt_strlen(null) is 0");
    assert_eq_i64(strlen(""), 0, "strlen of empty string is 0");

    // Test: Arena allocation alignment
    STDOUT.write_str("\n--- Arena Allocation Alignment ---\n");
    
    {
        Arena arena = Arena.new(1024);
        
        u8* byte_ptr = arena_alloc<u8>(&arena);
        *byte_ptr = 0;
        
        f64* double_ptr = arena_alloc<f64>(&arena);
        *double_ptr = 3.14;
        assert_true(((i64)double_ptr % 8) == 0, "f64 after u8 is 8-byte aligned");
        
        byte_ptr = arena_alloc<u8>(&arena);
        *byte_ptr = 0;
        
        f64* triple = arena_alloc_n<f64>(&arena, 3);
        triple[0] = 1.0;
        triple[1] = 2.0;
        triple[2] = 3.0;
        assert_true(((i64)triple % 8) == 0, "arena_alloc_n<f64>(3) after odd offset is 8-byte aligned");
        
        arena.drop();
    }

    // Test: Aligned zero-sized allocation freed through libc free shim
    STDOUT.write_str("\n--- Aligned Zero-Sized Free (PR 7 fix check) ---\n");
    {
        u8* ptr_4096 = silver_rt_alloc(0, 4096);
        assert_true(ptr_4096 != (u8*)0, "silver_rt_alloc(0, 4096) returns non-null");
        assert_true(((i64)ptr_4096 % 4096) == 0, "silver_rt_alloc(0, 4096) is aligned");
        
        u8* ptr_8192 = silver_rt_alloc(0, 8192);
        assert_true(ptr_8192 != (u8*)0, "silver_rt_alloc(0, 8192) returns non-null");
        assert_true(((i64)ptr_8192 % 8192) == 0, "silver_rt_alloc(0, 8192) is aligned");

        u8* ptr_huge = silver_rt_alloc(0, 33554432);
        assert_true(ptr_huge != (u8*)0, "silver_rt_alloc(0, 33554432) returns non-null");
        assert_true((i64)ptr_huge < 33554432, "silver_rt_alloc(0, 33554432) returns sentinel below threshold");
        
        free(ptr_4096);
        free(ptr_8192);
        free(ptr_huge);
        check(true, "Freeing page-aligned and large-aligned zero-sized allocations is successful");
    }

    return done();
}
