// Test suite for std.fmt — pure-Silver number formatting and print I/O.
import std.io;
import std.fmt;

extern "C" {
    i32 memcmp(const void* a, const void* b, i64 n);
    i64 strlen(const char* s);
}

i32 tests_passed = 0;
i32 tests_failed = 0;

struct CaseBuf {
    u8 data[400];
}

void check_buf(u8* got, i64 got_len, str expected, str msg) {
    i64 exp_len = strlen(expected);
    bool ok = got_len == exp_len;
    if (ok) {
        ok = memcmp((const void*)got, (const void*)expected, exp_len) == 0;
    }
    if (ok) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        got[got_len] = (u8)0;
        printf("  [FAIL] %s (expected \"%s\", got \"%s\" len=%ld)\n", msg, expected, (char*)got, got_len);
    }
}

void assert_true(bool cond, str msg) {
    if (cond) {
        tests_passed = tests_passed + 1;
        printf("  [PASS] %s\n", msg);
    } else {
        tests_failed = tests_failed + 1;
        printf("  [FAIL] %s\n", msg);
    }
}

void check_itoa(i64 v, str expected, str msg) {
    CaseBuf b;
    u8* p = (u8*)&b;
    i64 n = itoa(v, p);
    check_buf(p, n, expected, msg);
}

void check_utoa(u64 v, str expected, str msg) {
    CaseBuf b;
    u8* p = (u8*)&b;
    i64 n = utoa(v, p);
    check_buf(p, n, expected, msg);
}

void check_btoa(bool v, str expected, str msg) {
    CaseBuf b;
    u8* p = (u8*)&b;
    i64 n = btoa(v, p);
    check_buf(p, n, expected, msg);
}

void check_ftoa(f64 v, str expected, str msg) {
    CaseBuf b;
    u8* p = (u8*)&b;
    i64 n = ftoa(v, p);
    check_buf(p, n, expected, msg);
}

f64 f64_from_bits(u64 bits) {
    u64 tmp = bits;
    f64* fp = (f64*)&tmp;
    return *fp;
}

i32 main() {
    printf("=== fmt Tests ===\n\n");

    printf("--- itoa ---\n");
    check_itoa(0, "0", "itoa(0)");
    check_itoa(1, "1", "itoa(1)");
    check_itoa(-1, "-1", "itoa(-1)");
    check_itoa(42, "42", "itoa(42)");
    check_itoa(-42, "-42", "itoa(-42)");
    check_itoa(1000000, "1000000", "itoa(1000000)");
    check_itoa(-9223372036854775808, "-9223372036854775808", "itoa(i64::MIN)");
    check_itoa(9223372036854775807, "9223372036854775807", "itoa(i64::MAX)");

    printf("\n--- utoa ---\n");
    check_utoa((u64)0, "0", "utoa(0)");
    check_utoa((u64)1, "1", "utoa(1)");
    check_utoa((u64)10, "10", "utoa(10)");
    check_utoa((u64)9223372036854775808, "9223372036854775808", "utoa(2^63)");
    check_utoa((u64)12345678901234567890, "12345678901234567890", "utoa(12345678901234567890)");
    check_utoa((u64)18446744073709551615, "18446744073709551615", "utoa(u64::MAX)");

    printf("\n--- btoa ---\n");
    check_btoa(true, "true", "btoa(true)");
    check_btoa(false, "false", "btoa(false)");

    printf("\n--- ftoa: zero and specials ---\n");
    check_ftoa(0.0, "0", "ftoa(0.0)");
    f64 zero = 0.0;
    check_ftoa(-zero, "-0", "ftoa(-0.0)");
    check_ftoa(f64_from_bits((u64)9223372036854775808), "-0", "ftoa(-0.0 via bits)");
    check_ftoa(f64_from_bits((u64)9221120237041090560), "NaN", "ftoa(NaN)");
    check_ftoa(f64_from_bits((u64)18444492273895866368), "NaN", "ftoa(-NaN prints NaN)");
    check_ftoa(f64_from_bits((u64)9218868437227405312), "inf", "ftoa(inf)");
    check_ftoa(f64_from_bits((u64)18442240474082181120), "-inf", "ftoa(-inf)");

    printf("\n--- ftoa: simple values ---\n");
    check_ftoa(1.5, "1.5", "ftoa(1.5)");
    check_ftoa(0.1, "0.1", "ftoa(0.1)");
    check_ftoa(3.0, "3", "ftoa(3.0)");
    check_ftoa(-42.0, "-42", "ftoa(-42.0)");
    check_ftoa(2.5, "2.5", "ftoa(2.5)");
    check_ftoa(0.3, "0.3", "ftoa(0.3)");
    check_ftoa(123.456, "123.456", "ftoa(123.456)");
    check_ftoa(1.0 / 3.0, "0.3333333333333333", "ftoa(1/3)");

    printf("\n--- ftoa: large/small magnitudes (positional, like Rust Display) ---\n");
    check_ftoa(1000000000000000000000.0, "1000000000000000000000", "ftoa(1e21)");
    check_ftoa(100000000000000000000.0, "100000000000000000000", "ftoa(1e20)");
    check_ftoa(0.0000001, "0.0000001", "ftoa(1e-7)");
    check_ftoa(0.00001, "0.00001", "ftoa(1e-5)");
    check_ftoa(9007199254740993.0, "9007199254740992", "ftoa(9007199254740993 rounds to nearest f64)");

    printf("\n--- ftoa: extreme values (structural) ---\n");
    {
        // Smallest subnormal 5e-324: "0." + 323 zeros + "5" (326 chars).
        CaseBuf b;
        u8* p = (u8*)&b;
        i64 n = ftoa(f64_from_bits((u64)1), p);
        bool ok = n == 326;
        if (ok) {
            ok = p[0] == (u8)48 && p[1] == (u8)46 && p[325] == (u8)53;
        }
        if (ok) {
            i64 i = 2;
            while (i < 325) {
                if (p[i] != (u8)48) {
                    ok = false;
                }
                i = i + 1;
            }
        }
        assert_true(ok, "ftoa(5e-324) is 0.<323 zeros>5");
    }
    {
        // Largest finite f64: "17976931348623157" + 292 zeros (309 chars).
        CaseBuf b;
        u8* p = (u8*)&b;
        i64 n = ftoa(f64_from_bits((u64)9218868437227405311), p);
        bool ok = n == 309;
        if (ok) {
            str prefix = "17976931348623157";
            ok = memcmp((const void*)p, (const void*)prefix, 17) == 0;
        }
        if (ok) {
            i64 i = 17;
            while (i < 309) {
                if (p[i] != (u8)48) {
                    ok = false;
                }
                i = i + 1;
            }
        }
        assert_true(ok, "ftoa(f64::MAX) is 17976931348623157<292 zeros>");
    }

    printf("\n--- utf8 validation ---\n");
    {
        CaseBuf b;
        u8* p = (u8*)&b;
        p[0] = (u8)104; // "hi"
        p[1] = (u8)105;
        assert_true(is_valid_utf8(p, 2), "ascii is valid utf8");
        p[0] = (u8)206; // U+03B1 greek alpha: CE B1
        p[1] = (u8)177;
        assert_true(is_valid_utf8(p, 2), "2-byte sequence valid");
        assert_true(!is_valid_utf8(p, 1), "truncated sequence invalid");
        p[0] = (u8)237; // ED A0 80 = surrogate D800, must be rejected
        p[1] = (u8)160;
        p[2] = (u8)128;
        assert_true(!is_valid_utf8(p, 3), "surrogate rejected");
        p[0] = (u8)192; // C0 80 overlong NUL
        p[1] = (u8)128;
        assert_true(!is_valid_utf8(p, 2), "overlong rejected");
        p[0] = (u8)244; // F4 90 80 80 = U+110000 out of range
        p[1] = (u8)144;
        p[2] = (u8)128;
        p[3] = (u8)128;
        assert_true(!is_valid_utf8(p, 4), "codepoint above U+10FFFF rejected");
        p[0] = (u8)240; // F0 9F 92 96 = U+1F496 sparkling heart
        p[1] = (u8)159;
        p[2] = (u8)146;
        p[3] = (u8)150;
        assert_true(is_valid_utf8(p, 4), "4-byte sequence valid");
    }

    printf("\n--- write helpers ---\n");
    {
        i64 r = write_stdout((u8*)"  [smoke] write_stdout ok\n", 26);
        assert_true(r == 26, "write_stdout returns byte count");
    }

    printf("\n--- silver_rt print surface (smoke, check output manually) ---\n");
    silver_rt_print_i64(-42);
    silver_rt_print_u64((u64)18446744073709551615);
    silver_rt_print_bool((u8)1);
    silver_rt_print_bool((u8)0);
    silver_rt_print_f64(2.5);
    {
        str msg = "cstr line";
        silver_rt_print_cstr((char*)msg);
        SilverSlice s;
        s.ptr = (u8*)msg;
        s.len = 4;
        silver_rt_print_bytes(s); // prints "cstr" with NO newline
        s.ptr = (u8*)0;
        s.len = 0;
        silver_rt_print_bytes(s); // prints "<null>" WITH newline
        silver_rt_print_cstr((char*)0);
    }

    printf("\nTests passed: %d, failed: %d\n", tests_passed, tests_failed);
    return tests_failed;
}
