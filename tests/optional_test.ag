// Test suite for std.optional - Optional and Result types
//
// LIMITATION: the aborting paths (Optional.unwrap on none, Result.unwrap
// on err, Result.get_error on ok) are intentionally NOT exercised here.
// They terminate the process via abort(), and this harness runs in-process
// (no child-process spawning), so asserting an abort would kill the test
// runner itself.  This suite must exit 0; only the non-aborting paths are
// covered.
import std.test;
import std.optional;
import std.mem.alloc;
i32 main() {
    STDOUT.write_str("=== Optional<i32> Tests ===\n\n");
    
    // Test: None creation
    STDOUT.write_str("--- None Creation ---\n");
    
    Optional<i32> none = Optional<i32>.none();
    assert_true(none.is_none(), "none() creates empty optional");
    assert_true(!none.is_some(), "none is_some() returns false");
    
    // Test: Some creation
    STDOUT.write_str("\n--- Some Creation ---\n");
    
    Optional<i32> some = Optional<i32>.some(42);
    assert_true(some.is_some(), "some() creates valued optional");
    assert_true(!some.is_none(), "some is_none() returns false");
    assert_eq_i32(some.unwrap(), 42, "unwrap() returns correct value");
    
    // Test: unwrap_or
    STDOUT.write_str("\n--- unwrap_or ---\n");
    
    assert_eq_i32(some.unwrap_or(99), 42, "unwrap_or() returns value when Some");
    assert_eq_i32(none.unwrap_or(99), 99, "unwrap_or() returns default when None");
    
    // Test: Various values
    STDOUT.write_str("\n--- Various Values ---\n");
    
    Optional<i32> zero = Optional<i32>.some(0);
    assert_true(zero.is_some(), "some(0) is still Some");
    assert_eq_i32(zero.unwrap(), 0, "some(0) unwraps to 0");
    
    Optional<i32> negative = Optional<i32>.some(-100);
    assert_eq_i32(negative.unwrap(), -100, "negative values work");
    
    // Test: Optional<i64>
    STDOUT.write_str("\n=== Optional<i64> Tests ===\n\n");
    
    Optional<i64> none64 = Optional<i64>.none();
    assert_true(none64.is_none(), "Optional<i64>.none() works");
    
    Optional<i64> some64 = Optional<i64>.some(9223372036854775807);  // Max i64
    assert_true(some64.is_some(), "Optional<i64>.some() works with large value");
    assert_eq_i64(some64.unwrap(), (i64)9223372036854775807, "large i64 value preserved");
    
    // Test: Optional<f64>
    STDOUT.write_str("\n=== Optional<f64> Tests ===\n\n");
    
    Optional<f64> none_f = Optional<f64>.none();
    assert_true(none_f.is_none(), "Optional<f64>.none() works");
    
    Optional<f64> some_f = Optional<f64>.some(3.14159);
    assert_true(some_f.is_some(), "Optional<f64>.some() works");
    
    f64 val = some_f.unwrap();
    assert_true(val > 3.14 && val < 3.15, "f64 value preserved");
    
    f64 default_f = none_f.unwrap_or(2.71828);
    assert_true(default_f > 2.71 && default_f < 2.72, "unwrap_or() works for f64");
    
    // Test: Optional<void*> (pointer)
    STDOUT.write_str("\n=== Optional<void*> Tests ===\n\n");
    
    Optional<void*> none_p = Optional<void*>.none();
    assert_true(none_p.is_none(), "Optional<void*>.none() works");
    
    i32 x = 42;
    Optional<void*> some_p = Optional<void*>.some(&x);
    assert_true(some_p.is_some(), "Optional<void*>.some() works");
    
    i32* ptr = (i32*)(some_p.unwrap());
    assert_eq_i32(*ptr, 42, "pointer value accessible through optional");
    
    void* default_ptr = none_p.unwrap_or(&x);
    assert_true(default_ptr == (void*)&x, "unwrap_or() returns default pointer");
    
    // Test: Result<i32, i32>
    STDOUT.write_str("\n=== Result<i32, i32> Tests ===\n\n");
    
    // Test: Ok creation
    STDOUT.write_str("--- Ok Creation ---\n");
    
    Result<i32, i32> ok_result = Result<i32, i32>.ok(100);
    assert_true(ok_result.success(), "ok() creates successful result");
    assert_true(!ok_result.failed(), "ok() result is not failed");
    assert_eq_i32(ok_result.unwrap(), 100, "ok() unwrap returns value");
    // NOTE: get_error() on an ok result now aborts (it previously returned
    // uninitialized memory), so it is only called on err results below.
    
    // Test: Err creation
    STDOUT.write_str("\n--- Err Creation ---\n");
    
    Result<i32, i32> err_result = Result<i32, i32>.err(404);
    assert_true(err_result.failed(), "err() creates failed result");
    assert_true(!err_result.success(), "err() result is not success");
    assert_eq_i32(err_result.get_error(), 404, "err() returns error code");
    
    // Test: unwrap_or on Result
    STDOUT.write_str("\n--- Result unwrap_or ---\n");
    
    assert_eq_i32(ok_result.unwrap_or(-1), 100, "ok unwrap_or returns value");
    assert_eq_i32(err_result.unwrap_or(-1), -1, "err unwrap_or returns default");
    
    // Test: Simulated use case
    STDOUT.write_str("\n=== Simulated Use Cases ===\n\n");
    
    // Simulate a function that might fail
    STDOUT.write_str("Simulating division:\n");
    
    // divide(10, 2) -> Ok(5)
    i32 a = 10;
    i32 b = 2;
    Result<i32, i32> div1;
    if (b != 0) {
        div1 = Result<i32, i32>.ok(a / b);
    } else {
        div1 = Result<i32, i32>.err(1);  // Division by zero error
    }
    assert_true(div1.success(), "10/2 succeeds");
    assert_eq_i32(div1.unwrap(), 5, "10/2 = 5");
    
    // divide(10, 0) -> Err(1)
    b = 0;
    Result<i32, i32> div2;
    if (b != 0) {
        div2 = Result<i32, i32>.ok(a / b);
    } else {
        div2 = Result<i32, i32>.err(1);
    }
    assert_true(div2.failed(), "10/0 fails");
    assert_eq_i32(div2.get_error(), 1, "10/0 returns error code 1");
    
    // Simulate looking up a value
    STDOUT.write_str("\nSimulating lookup:\n");
    
    i32* array = alloc<i32>(5);
    array[0] = 10;
    array[1] = 20;
    array[2] = 30;
    array[3] = 40;
    array[4] = 50;
    
    // lookup(array, 2) -> Some(30)
    i32 idx = 2;
    Optional<i32> lookup1;
    if (idx >= 0 && idx < 5) {
        lookup1 = Optional<i32>.some(array[idx]);
    } else {
        lookup1 = Optional<i32>.none();
    }
    assert_true(lookup1.is_some(), "valid index returns Some");
    assert_eq_i32(lookup1.unwrap(), 30, "correct value returned");
    
    // lookup(array, 10) -> None
    idx = 10;
    Optional<i32> lookup2;
    if (idx >= 0 && idx < 5) {
        lookup2 = Optional<i32>.some(array[idx]);
    } else {
        lookup2 = Optional<i32>.none();
    }
    assert_true(lookup2.is_none(), "invalid index returns None");
    assert_eq_i32(lookup2.unwrap_or(-1), -1, "default value used for invalid index");
    
    // Summary
    STDOUT.write_str("\n=== Results ===\n");
    STDOUT.write_str("Passed: ");
    STDOUT.write_i64(tests_passed);
    STDOUT.write_str(", Failed: ");
    STDOUT.write_i64(tests_failed);
    STDOUT.write_str("\n");
    
    if (tests_failed > 0) {
        return 1;
    }
    return 0;
}
