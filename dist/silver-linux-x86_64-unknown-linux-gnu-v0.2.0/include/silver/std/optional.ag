struct Optional<T> {
    bool present;
    T thing;
}

impl Optional<T> {
    Optional<T> none() {
        Optional<T> value;
        value.present = false;
        return value;
    }

    Optional<T> some(T thing) {
        Optional<T> value;
        value.present = true;
        value.thing = thing;
        return value;
    }

    bool is_some(Optional<T> self) {
        return self.present;
    }

    bool is_none(Optional<T> self) {
        return !self.present;
    }

    T unwrap(Optional<T> self) {
        return self.thing;
    }

    T unwrap_or(Optional<T> self, T fallback) {
        if (self.present) {
            return self.thing;
        }
        return fallback;
    }
}

struct Result<T, E> {
    bool ok;
    T value;
    E error;
}

impl Result<T, E> {
    Result<T, E> ok(T value) {
        Result<T, E> result;
        result.ok = true;
        result.value = value;
        return result;
    }

    Result<T, E> err(E error) {
        Result<T, E> result;
        result.ok = false;
        result.error = error;
        return result;
    }

    bool success(Result<T, E> self) {
        return self.ok;
    }

    bool failed(Result<T, E> self) {
        return !self.ok;
    }

    T unwrap(Result<T, E> self) {
        return self.value;
    }

    T unwrap_or(Result<T, E> self, T fallback) {
        if (self.ok) {
            return self.value;
        }
        return fallback;
    }

    E get_error(Result<T, E> self) {
        return self.error;
    }
}
