/// Boxed heap-allocated values.
///
/// `Box<T>` is a smart pointer that owns a dynamically allocated value of type `T` on the heap.
/// When the box goes out of scope, its destructor is automatically called, freeing the allocated memory.

import std.mem;
import std.mem.drop;

pub struct Box<T> {
    T* ptr;
}

impl Box<T> {
    /// Allocates memory on the heap and moves `val` into it, returning a new `Box<T>`.
    pub Box<T> new(T val) {
        T* p = alloc<T>();
        *p = val;
        Box<T> b;
        b.ptr = p;
        return b;
    }

    /// Returns a pointer to the inner boxed value.
    pub T* get(Box<T>* self) {
        return self.ptr;
    }
}

impl<T> Drop<Box<T>> for Box<T> {
    /// Frees the heap-allocated memory associated with this box.
    pub void drop(Box<T>* self) {
        if (self.ptr != (T*)0) {
            free(self.ptr);
            self.ptr = (T*)0;
        }
    }
}
