// Generic contiguous-growable array (Vec<T>).
//
// Memory management (malloc/realloc/free) is linked from the C runtime;
// callers pay only for elements they push.  O(1) amortized push, O(1) index.
//
// A Vec<T>'s drop method frees the backing buffer automatically.
//
// LIMITATIONS
// ───────────
// Drop does NOT call per-element destructors — the type system cannot
// currently iterate elements on drop.  For owned-element types, use
// `get_ptr` for read-only access and `take` to extract values before
// the Vec goes out of scope.  POD types (i32, structs of i32, etc.)
// are always safe.
import std.mem.alloc;
import std.mem.drop;
import std.ops;
import std.optional;
import std.iter;
/// A contiguous, growable array type.
pub struct Vec<T> {
    T* data;
    i64 len;
    i64 cap;
}

impl Vec<T> {
    /// Empty vector — no allocation.
    pub Vec<T> new() {
        Vec<T> v;
        v.data = (T*)0;
        v.len = 0;
        v.cap = 0;
        return move v;
    }

    /// Reserve space for `capacity` elements up front.
    pub Vec<T> with_capacity(i64 capacity) {
        Vec<T> v;
        v.data = (T*)(0);
        if (capacity != 0) {
            v.data = (T*)(malloc(@size(T) * capacity));
        }
        v.len = 0;
        v.cap = capacity;
        return move v;
    }

    // -- Size / capacity ------------------------------------------------

    /// Number of elements currently in the vector.
    pub i64 len(Vec<T>* self) {
        return self.len;
    }

    /// Total allocated capacity.
    pub i64 capacity(Vec<T>* self) {
        return self.cap;
    }

    /// True when `len` is zero.
    pub bool is_empty(Vec<T>* self) {
        return self.len == 0;
    }

    // -- Element access -------------------------------------------------

    /// Read element at `index`.  Returns a COPY — for owned-element types
    /// this creates a shallow copy that shares resources with the backing
    /// buffer.  Prefer `get_ptr` or `take` for owned types.
    pub T get(Vec<T>* self, i64 index) {
        return self.data[index];
    }

    /// Pointer to element at `index`.
    pub T* get_ptr(Vec<T>* self, i64 index) {
        return &(self.data[index]);
    }

    /// Overwrite element at `index`.
    pub void set(Vec<T>* self, i64 index, T value) {
        self.data[index] = move value;
    }

    // -- Mutation -------------------------------------------------------

    /// Append `value` to the end (O(1) amortized).
    pub void push(Vec<T>* self, T value) {
        if (self.len >= self.cap) {
            i64 new_cap = 1;
            if (self.cap != 0) {
                new_cap = self.cap * 2;
            }
            self.data = (T*)(realloc(self.data, @size(T) * new_cap));
            self.cap = new_cap;
        }
        self.data[self.len] = move value;
        self.len = self.len + 1;
    }

    /// Remove and return the last element.  Assumes `len > 0`.
    /// The stale slot retains a copy; do NOT read a popped index.
    pub T pop(Vec<T>* self) {
        self.len = self.len - 1;
        T result = self.data[self.len];
        return move result;
    }

    /// Move value out of position `index`.
    pub T take(Vec<T>* self, i64 index) {
        T result = self.data[index];
        return move result;
    }

    /// Remove all elements without freeing the backing buffer.
    pub void clear(Vec<T>* self) {
        self.len = 0;
    }

    /// Reserve at least `min_capacity` elements, growing if needed.
    pub void reserve(Vec<T>* self, i64 min_capacity) {
        if (self.cap >= min_capacity) {
            return;
        }
        self.data = (T*)(realloc(self.data, @size(T) * min_capacity));
        self.cap = min_capacity;
    }

    /// Shrink capacity to match length.
    pub void shrink_to_fit(Vec<T>* self) {
        if (self.len == 0) {
            if (self.data != (T*)0) {
                free(self.data);
            }
            self.data = (T*)0;
            self.cap = 0;
        } else {
            if (self.len < self.cap) {
                self.data = (T*)(realloc(self.data, @size(T) * self.len));
                self.cap = self.len;
            }
        }
    }
}

impl<T> Drop<Vec<T>> for Vec<T> {
    /// Frees the backing buffer.  Does NOT call per-element destructors
    /// (the type system currently does not iterate elements on drop).
    pub void drop(Vec<T>* self) {
        if (self.data != (T*)0) {
            free(self.data);
            self.data = (T*)0;
        }
        self.len = 0;
        self.cap = 0;
    }
}
impl<T> IndexedAccess<Vec<T>> for Vec<T> {
    type Item = T;
    T __index_get(Vec<T>* self, i64 index) {
        if (index < 0 || index >= self.len) { abort(); }
        return self.data[index];
    }
    void __index_set(Vec<T>* self, i64 index, T value) {
        if (index < 0 || index >= self.len) { abort(); }
        self.data[index] = move value;
    }
}

// -- Iterator support ---------------------------------------------------
//
// VecIter<T> is an iterator over Vec<T> elements.  It borrows the Vec's
// backing buffer during iteration.  The Vec is consumed by into_iter()
// (its data pointer is cleared to prevent double-free on drop), and the
// buffer is freed when the original Vec variable goes out of scope.
//
// VecIter does NOT implement Drop — the Vec's Drop handles the buffer.

/// Iterator over Vec<T> elements.
pub struct VecIter<T> {
    T* data;
    i64 len;
    i64 idx;
}

impl<T> Vec<T> {
    /// Consume the Vec and return an iterator over its elements.
    pub VecIter<T> into_iter(Vec<T>* self) {
        VecIter<T> iter;
        iter.data = self.data;
        iter.len = self.len;
        iter.idx = 0;
        // Clear the Vec's buffer reference so its drop won't free it.
        // The original variable still owns the buffer and frees it on
        // its own drop — VecIter borrows the data during iteration.
        self.data = (T*)0;
        self.len = 0;
        self.cap = 0;
        return iter;
    }
}

impl<T> Iterator<VecIter<T>> for VecIter<T> {
    type Item = T;
    /// Returns the next element in the iteration sequence, or an empty Optional when done.
    Optional<T> next(VecIter<T>* self) {
        if (self.idx < self.len) {
            T value = self.data[self.idx];
            self.idx = self.idx + 1;
            Optional<T> result;
            result.present = true;
            result.thing = value;
            return result;
        }
        Optional<T> result;
        result.present = false;
        return result;
    }
}
