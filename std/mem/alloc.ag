#[link(c)]

pub T* alloc<T>() {
    return (T*)(malloc(@size(T)));
}

pub T* alloc<T>(i64 count) {
    return (T*)(calloc(count, @size(T)));
}

pub T* realloc<T>(T* ptr, i64 count) {
    return (T*)(realloc(ptr, @size(T) * count));
}

extern "C" {
    void abort();
    void* malloc(i64 size);
    void* calloc(i64 count, i64 size);
    void free(void* ptr);
    void* memset(void* ptr, i32 value, i64 num);
    void* memcpy(void* dest, const void* src, i64 num);
    void* memmove(void* dest, const void* src, i64 num);
    void* realloc(void* ptr, i64 new_size);
}
