/// Pure-Silver syscall wrappers for the Linux x86_64 syscall ABI.
///
/// Register mapping: rax=num, rdi=arg1, rsi=arg2, rdx=arg3, r10=arg4, r8=arg5, r9=arg6
/// Return: rax (always i64), error indicated by value in -4095..-1 range
///
/// Each wrapper passes the syscall number as the first asm input (→rax),
/// then args sequentially per the ABI. The asm returns a single i64 from rax.

/// Performs a 0-argument syscall.
/// Maps `num` to RAX.
pub i64 syscall0(i64 num) {
    return asm("syscall", [num]);
}

/// Performs a 1-argument syscall.
/// Maps `num` to RAX and `arg1` to RDI.
pub i64 syscall1(i64 num, i64 arg1) {
    return asm("syscall", [num, arg1]);
}

/// Performs a 2-argument syscall.
/// Maps `num` to RAX, `arg1` to RDI, and `arg2` to RSI.
pub i64 syscall2(i64 num, i64 arg1, i64 arg2) {
    return asm("syscall", [num, arg1, arg2]);
}

/// Performs a 3-argument syscall.
/// Maps `num` to RAX, `arg1` to RDI, `arg2` to RSI, and `arg3` to RDX.
pub i64 syscall3(i64 num, i64 arg1, i64 arg2, i64 arg3) {
    return asm("syscall", [num, arg1, arg2, arg3]);
}

/// Performs a 4-argument syscall.
/// Maps `num` to RAX, `arg1` to RDI, `arg2` to RSI, `arg3` to RDX, and `arg4` to R10.
pub i64 syscall4(i64 num, i64 arg1, i64 arg2, i64 arg3, i64 arg4) {
    return asm("syscall", [num, arg1, arg2, arg3, arg4]);
}

/// Performs a 5-argument syscall.
/// Maps `num` to RAX, `arg1` to RDI, `arg2` to RSI, `arg3` to RDX, `arg4` to R10, and `arg5` to R8.
pub i64 syscall5(i64 num, i64 arg1, i64 arg2, i64 arg3, i64 arg4, i64 arg5) {
    return asm("syscall", [num, arg1, arg2, arg3, arg4, arg5]);
}

/// Performs a 6-argument syscall.
/// Maps `num` to RAX, `arg1` to RDI, `arg2` to RSI, `arg3` to RDX, `arg4` to R10, `arg5` to R8, and `arg6` to R9.
pub i64 syscall6(i64 num, i64 arg1, i64 arg2, i64 arg3, i64 arg4, i64 arg5, i64 arg6) {
    return asm("syscall", [num, arg1, arg2, arg3, arg4, arg5, arg6]);
}
