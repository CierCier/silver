// std/sys/entry.ag — Silver _start entry point for static (no-libc) binaries.
import std.io;
//
// Importing this module inlines a `_start` symbol that:
//   1. Zeroes %rbp (ABI: marks outermost stack frame).
//   2. Loads argc from (%rsp) into %rdi (first arg to main).
//   3. Computes argv = rsp+8 into %rsi (second arg, for future use).
//   4. Re-aligns the stack to 16 bytes (and $-16, %rsp).
//   5. Calls main().
//   6. Saves return value in %r12, calls __silver_flush_all() to flush any
//      buffered I/O (BufWriter STDOUT/STDERR).
//   7. Restores the return value into %rdi and invokes exit_group via syscall 231.
//
// Usage:
//   import std.sys.entry;       // in any Silver program compiled with --static-runtime
//   i32 main() { return 0; }
//
// The module's _start is inlined into the consumer's object file by the import
// hook, so no separate linking step is needed.
extern "C" {
    i32 main();
    i32 __silver_argc;
    i8** __silver_argv;
}

pub i32 silver_argc() {
    return __silver_argc;
}

pub i8** silver_argv() {
    return __silver_argv;
}

void _start() {
    asm(".section .bss\n__silver_argc: .zero 4\n__silver_argv: .zero 8\n.text\nxor %ebp, %ebp\nmov (%rsp), %rdi\nlea 8(%rsp), %rsi\nmov %rdi, __silver_argc(%rip)\nmov %rsi, __silver_argv(%rip)\nand $$-16, %rsp\ncall main\nmov %rax, %r12\ncall __silver_flush_all\nmov %r12, %rdi\nmov $$231, %eax\nsyscall");
}
