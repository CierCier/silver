// std/io.ag — Silver I/O: pure-Silver print path, typed-syscall File API.
//
// The plain print path (println/eprintln) writes through raw sys_write via
// std.fmt (pure Silver, no printf/puts).  The File API runs directly on the
// typed syscall layer (std.sys.result: try_open/try_read/try_write/
// try_close/try_lseek) — no FILE*, no libc stdio buffering.

import std.fmt;
import std.mem.vec;
import std.sys.result;

const i32 EOF = -1;

// Seek origins for File.seek_from (values match lseek(2) whence).
enum IO_SEEK {
    SET = 0;
    CURSOR = 1;
    END = 2;
}


// ---------------------------------------------------------------------------
// BufWriter — buffered I/O backed by a growable heap buffer and a raw fd.
// Provides write_str/write_i64/write_u64/write_f64/write_bool for the
// compile-time print expansion and manual formatting use.
// Global instances STDOUT and STDERR are lazy-initialized (cap == 0).
//
// We store the buffer address as `i64` rather than `u8*` so the global
// initializer (which runs at compile time) can use integer 0 instead of
// a null-pointer literal.
// ---------------------------------------------------------------------------

pub struct BufWriter {
    i64 data;   // address of buffer (0 = uninitialized)
    i64 len;
    i64 cap;
    i64 fd;
}

// Zero-cost global instances (all zero → triggers lazy init on first write).
pub BufWriter STDOUT = { .data = 0, .len = 0, .cap = 0, .fd = 1 };
pub BufWriter STDERR = { .data = 0, .len = 0, .cap = 0, .fd = 2 };

// Scratch buffers for number formatting.
struct __Buf32 { u8 data[32]; }
struct __Buf64 { u8 data[64]; }

impl BufWriter {
    /// Ensure internal buffer is initialized (lazy mmap).
    void ensure_init(BufWriter* self) {
        if ((*self).cap == 0) {
            Vec<u8> v = Vec<u8>.with_capacity(4096);
            (*self).data = (i64)v.data;
            (*self).len = v.len;
            (*self).cap = v.cap;
        }
    }

    /// Buffer a write.  Does NOT flush unless the buffer is full.
    pub void write(BufWriter* self, u8* src, i64 n) {
        self.ensure_init();
        // Grow if needed
        if ((*self).len + n > (*self).cap) {
            i64 new_cap = (*self).cap * 2;
            if (new_cap < (*self).len + n) {
                new_cap = (*self).len + n;
            }
            u8* ptr = (u8*)realloc<u8>((u8*)(*self).data, new_cap);
            (*self).data = (i64)ptr;
            (*self).cap = new_cap;
        }
        // Copy bytes
        u8* buf = (u8*)(*self).data;
        i64 i = 0;
        while (i < n) {
            buf[(*self).len + i] = src[i];
            i = i + 1;
        }
        (*self).len = (*self).len + n;
        // Auto-flush on newline (line-buffered semantics)
        if (n > 0 && src[n - 1] == (u8)10) {
            self.flush();
        }
    }

    /// Write a null-terminated string.
    pub void write_str(BufWriter* self, str s) {
        self.write((u8*)s, cstr_len((u8*)s));
    }

    /// Format and buffer an i64 value.
    pub void write_i64(BufWriter* self, i64 v) {
        __Buf32 tmp;
        u8* p = (u8*)&tmp;
        i64 n = itoa(v, p);
        self.write(p, n);
    }

    /// Format and buffer a u64 value.
    pub void write_u64(BufWriter* self, u64 v) {
        __Buf32 tmp;
        u8* p = (u8*)&tmp;
        i64 n = utoa(v, p);
        self.write(p, n);
    }

    /// Format and buffer an f64 value.
    pub void write_f64(BufWriter* self, f64 v) {
        __Buf64 tmp;
        u8* p = (u8*)&tmp;
        i64 n = ftoa(v, p);
        self.write(p, n);
    }

    /// Format and buffer a bool value.
    pub void write_bool(BufWriter* self, bool v) {
        if (v) { self.write_str("true"); }
        else   { self.write_str("false"); }
    }

    /// Flush buffered data to the underlying fd via a single sys_write call.
    pub void flush(BufWriter* self) {
        self.ensure_init();
        if ((*self).len > 0) {
            __fmt_write_fd((*self).fd, (u8*)(*self).data, (*self).len);
            (*self).len = 0;
        }
    }

    /// Drop: flush remaining data, then free the buffer.
    pub void drop(BufWriter* self) {
        self.flush();
        if ((*self).cap > 0) {
            free((void*)(*self).data);
            (*self).data = 0;
            (*self).cap = 0;
        }
    }
}
// File — a typed-syscall file descriptor wrapper.
//
// Holds the raw fd and an open flag; unbuffered (every operation is one
// syscall).  `at_eof`/`had_error` remember the last read result so
// eof()/error() behave like their stdio predecessors.
struct File {
    i32 fd;
    bool is_open;
    bool at_eof;
    bool had_error;
}

impl File {
    File from_fd(i32 fd) {
        File file = { .fd = fd, .is_open = fd >= 0, .at_eof = false, .had_error = false };
        return file;
    }

    File closed() {
        File file = { .fd = -1, .is_open = false, .at_eof = false, .had_error = false };
        return file;
    }

    /// fopen-style mode string -> open(2) flags.  Unknown/empty modes
    /// conservatively map to O_RDONLY.
    i64 mode_flags(str mode) {
        if (mode == (str)0) {
            return O_RDONLY;
        }
        u8* m = (u8*)mode;
        u8 first = m[0];
        bool plus = cstr_contains(m, 43);   // '+'
        bool has_x = cstr_contains(m, 120); // 'x'
        if (first == (u8)114) {             // 'r'
            if (plus) {
                return O_RDWR;
            }
            return O_RDONLY;
        }
        if (first == (u8)119) {             // 'w'
            i64 flags = O_WRONLY | O_CREAT | O_TRUNC;
            if (plus) {
                flags = O_RDWR | O_CREAT | O_TRUNC;
            }
            if (has_x) {
                flags = flags | O_EXCL;
            }
            return flags;
        }
        if (first == (u8)97) {              // 'a'
            i64 flags = O_WRONLY | O_CREAT | O_APPEND;
            if (plus) {
                flags = O_RDWR | O_CREAT | O_APPEND;
            }
            if (has_x) {
                flags = flags | O_EXCL;
            }
            return flags;
        }
        return O_RDONLY;
    }

    File open(str path, str mode) {
        SysResult r = try_open(path, File.mode_flags(mode), 438); // 0o666
        if (r.is_err()) {
            return File.closed();
        }
        return File.from_fd((i32)r.value);
    }

    File open_read(str path) {
        return File.open(path, "r");
    }

    File open_write(str path) {
        return File.open(path, "w");
    }

    File open_append(str path) {
        return File.open(path, "a");
    }

    bool valid(File self) {
        return self.is_open && self.fd >= 0;
    }

    bool invalid(File self) {
        return !self.valid();
    }

    i32 close(File* self) {
        if ((*self).invalid()) {
            self.is_open = false;
            return 0;
        }
        SysResult r = try_close(self.fd);
        if (r.is_ok()) {
            self.fd = -1;
            self.is_open = false;
            return 0;
        }
        return (i32)r.errno;
    }

    /// No userspace buffer to flush: a valid fd is already flushed.
    i32 flush(File self) {
        if (self.invalid()) {
            return EOF;
        }
        return 0;
    }

    i32 read_char(File* self) {
        if ((*self).invalid()) {
            return EOF;
        }
        u8 ch = (u8)0;
        SysResult r = try_read(self.fd, &ch, 1);
        if (r.is_err()) {
            self.had_error = true;
            return EOF;
        }
        if (r.value == 0) {
            self.at_eof = true;
            return EOF;
        }
        return (i32)ch;
    }

    i32 write_char(File* self, i32 ch) {
        if ((*self).invalid()) {
            return EOF;
        }
        u8 b = (u8)ch;
        SysResult r = try_write(self.fd, &b, 1);
        if (r.is_err() || r.value != 1) {
            self.had_error = true;
            return EOF;
        }
        return ch;
    }

    i32 write_str(File* self, str text) {
        if ((*self).invalid()) {
            return EOF;
        }
        if (text == (str)0) {
            self.had_error = true;
            return EOF;
        }
        u8* p = (u8*)text;
        i64 len = cstr_len(p);
        i64 written = 0;
        while (written < len) {
            SysResult r = try_write(self.fd, (u8*)((i64)p + written), len - written);
            if (r.is_err()) {
                self.had_error = true;
                return EOF;
            }
            if (r.value == 0) {
                self.had_error = true;
                return EOF;
            }
            written = written + r.value;
        }
        return 0;
    }

    i32 write_line(File* self, str text) {
        if ((*self).invalid()) {
            return EOF;
        }
        i32 result = self.write_str(text);
        if (result < 0) {
            return result;
        }
        return self.write_char(10);
    }

    /// fread-shaped API: reads up to elem_size*elem_count bytes, returns
    /// whole elements read (0 at EOF or on error, like a short fread).
    i64 read(File* self, void* buffer, i64 elem_size, i64 elem_count) {
        if ((*self).invalid()) {
            return 0;
        }
        if (elem_size <= 0 || elem_count <= 0) {
            return 0;
        }
        i64 total = elem_size * elem_count;
        i64 done = 0;
        while (done < total) {
            SysResult r = try_read(self.fd, (u8*)((i64)buffer + done), total - done);
            if (r.is_err()) {
                self.had_error = true;
                break;
            }
            if (r.value == 0) {
                self.at_eof = true;
                break;
            }
            done = done + r.value;
        }
        return done / elem_size;
    }

    /// fwrite-shaped API: writes elem_size*elem_count bytes, returns whole
    /// elements written (short count on error, like fwrite).
    i64 write(File* self, const void* buffer, i64 elem_size, i64 elem_count) {
        if ((*self).invalid()) {
            return 0;
        }
        if (elem_size <= 0 || elem_count <= 0) {
            return 0;
        }
        i64 total = elem_size * elem_count;
        i64 done = 0;
        while (done < total) {
            SysResult r = try_write(self.fd, (u8*)((i64)buffer + done), total - done);
            if (r.is_err()) {
                self.had_error = true;
                break;
            }
            if (r.value == 0) {
                self.had_error = true;
                break;
            }
            done = done + r.value;
        }
        return done / elem_size;
    }

    bool seek(File* self, i64 offset) {
        return self.seek_from(offset, IO_SEEK.SET);
    }

    bool seek_to_start(File* self) {
        return self.seek_from(0, IO_SEEK.SET);
    }

    bool seek_to_end(File* self) {
        return self.seek_from(0, IO_SEEK.END);
    }

    bool seek_from(File* self, i64 offset, IO_SEEK origin) {
        if ((*self).invalid()) {
            return false;
        }
        SysResult r = try_lseek(self.fd, offset, (i64)((i32)origin));
        if (r.is_err()) {
            self.had_error = true;
            return false;
        }
        return true;
    }

    i64 tell(File* self) {
        if ((*self).invalid()) {
            return -1;
        }
        SysResult r = try_lseek(self.fd, 0, SEEK_CUR);
        if (r.is_err()) {
            self.had_error = true;
            return -1;
        }
        return r.value;
    }

    void rewind(File* self) {
        if ((*self).valid()) {
            self.seek_from(0, IO_SEEK.SET);
            self.at_eof = false;
            self.had_error = false;
        }
    }

    bool eof(File* self) {
        if ((*self).invalid()) {
            return true;
        }
        return self.at_eof;
    }

    bool error(File* self) {
        if ((*self).invalid()) {
            return true;
        }
        return self.had_error;
    }

    void clear_error(File* self) {
        if ((*self).valid()) {
            self.at_eof = false;
            self.had_error = false;
        }
    }

    i64 size(File* self) {
        if ((*self).invalid()) {
            return -1;
        }
        i64 pos = self.tell();
        if (pos < 0) {
            return -1;
        }
        SysResult end = try_lseek(self.fd, 0, SEEK_END);
        if (end.is_err()) {
            self.had_error = true;
            return -1;
        }
        self.seek_from(pos, IO_SEEK.SET);
        return end.value;
    }
}

// True when `needle` (a byte value) occurs in the null-terminated string `p`.
bool cstr_contains(u8* p, u8 needle) {
    i64 i = 0;
    while (p[i] != (u8)0) {
        if (p[i] == needle) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// Convenience constructors for the standard descriptors.
File stdin_file() {
    return File.from_fd(STDIN_FD);
}

File stdout_file() {
    return File.from_fd(STDOUT_FD);
}

File stderr_file() {
    return File.from_fd(STDERR_FD);
}

// High-level helpers. These write straight through the write(2) syscall
// (std.fmt), bypassing libc stdio buffering entirely.
i32 println(str text) {
    if (text == (str)0) {
        return EOF;
    }
    u8* p = (u8*)text;
    i64 len = cstr_len(p);
    if (write_stdout(p, len) < 0) {
        return EOF;
    }
    if (write_stdout((u8*)"\n", 1) < 0) {
        return EOF;
    }
    return (i32)(len + 1);
}

i32 eprintln(str text) {
    if (text == (str)0) {
        return EOF;
    }
    u8* p = (u8*)text;
    i64 len = cstr_len(p);
    if (write_stderr(p, len) < 0) {
        return EOF;
    }
    if (write_stderr((u8*)"\n", 1) < 0) {
        return EOF;
    }
    return (i32)(len + 1);
}

bool file_exists(str path) {
    File file = File.open_read(path);
    if (file.invalid()) {
        return false;
    }
    file.close();
    return true;
}

bool file_delete(str path) {
    return sys_unlink((i64)path) == 0;
}

bool file_rename(str from, str to) {
    return sys_rename((i64)from, (i64)to) == 0;
}
