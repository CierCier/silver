// std/io.ag — Silver I/O: pure-Silver print path, typed-syscall File API,
// and a small set of kept libc stdio externs.
//
// The plain print path (println/eprintln) writes through raw sys_write via
// std.fmt (pure Silver, no printf/puts).  The File API runs directly on the
// typed syscall layer (std.sys.result: try_open/try_read/try_write/
// try_close/try_lseek) — no FILE*, no libc stdio buffering.
//
// KEPT LIBC EXTERNS (live callers — removing them breaks the build):
//   printf   — every test's assert/print harness (tests/*.ag), plus
//              std/map.ag, std/slice.ag, std/rt/types.ag failure paths.
//   fprintf  — std/optional.ag unwrap failure messages (fprintf(stderr,..)).
//   puts     — tests/io_test.ag.
//   putchar  — tests/io_test.ag.
//   remove   — file_delete() below (callers: tests/file_test.ag).
//   rename   — file_rename() below (callers: tests/file_test.ag).
// stdin/stdout/stderr FILE* variables are kept solely as fprintf's stream
// operands.  All variadic/scan/temp/positioning stdio externs were removed
// with the FILE struct.

import std.fmt;
import std.sys.result;

const i32 EOF = -1;

// Seek origins for File.seek_from (values match lseek(2) whence).
enum IO_SEEK {
    SET = 0;
    CURSOR = 1;
    END = 2;
}

// Opaque FILE struct: only ever used behind a pointer (fprintf's stream).
struct FILE {
    i32 _opaque;
}

// Raw stdio symbols that still have live callers (see header comment).

extern "C" {

FILE* stdin;
FILE* stdout;
FILE* stderr;

i32 remove(const char* path);
i32 rename(const char* from, const char* to);

i32 fprintf(FILE* stream, const char* fmt, ...);
i32 printf(const char* fmt, ...);
i32 putchar(i32 ch);
i32 puts(const char* text);

} // Extern "C" End


// File — a typed-syscall file descriptor wrapper.
//
// Holds the raw fd and an open flag; unbuffered (every operation is one
// syscall).  `at_eof`/`had_error` remember the last read result so
// eof()/error() behave like their stdio predecessors.
struct File {
    i32 fd;
    bool is_open;
    bool at_eof;
    bool had_error;
}

impl File {
    File from_fd(i32 fd) {
        File file = { .fd = fd, .is_open = fd >= 0, .at_eof = false, .had_error = false };
        return file;
    }

    File closed() {
        File file = { .fd = -1, .is_open = false, .at_eof = false, .had_error = false };
        return file;
    }

    /// fopen-style mode string -> open(2) flags.  Unknown/empty modes
    /// conservatively map to O_RDONLY.
    i64 mode_flags(str mode) {
        if (mode == (str)0) {
            return O_RDONLY;
        }
        u8* m = (u8*)mode;
        u8 first = m[0];
        bool plus = cstr_contains(m, 43);   // '+'
        bool has_x = cstr_contains(m, 120); // 'x'
        if (first == (u8)114) {             // 'r'
            if (plus) {
                return O_RDWR;
            }
            return O_RDONLY;
        }
        if (first == (u8)119) {             // 'w'
            i64 flags = O_WRONLY | O_CREAT | O_TRUNC;
            if (plus) {
                flags = O_RDWR | O_CREAT | O_TRUNC;
            }
            if (has_x) {
                flags = flags | O_EXCL;
            }
            return flags;
        }
        if (first == (u8)97) {              // 'a'
            i64 flags = O_WRONLY | O_CREAT | O_APPEND;
            if (plus) {
                flags = O_RDWR | O_CREAT | O_APPEND;
            }
            if (has_x) {
                flags = flags | O_EXCL;
            }
            return flags;
        }
        return O_RDONLY;
    }

    File open(str path, str mode) {
        SysResult r = try_open(path, File.mode_flags(mode), 438); // 0o666
        if (r.is_err()) {
            return File.closed();
        }
        return File.from_fd((i32)r.value);
    }

    File open_read(str path) {
        return File.open(path, "r");
    }

    File open_write(str path) {
        return File.open(path, "w");
    }

    File open_append(str path) {
        return File.open(path, "a");
    }

    bool valid(File self) {
        return self.is_open && self.fd >= 0;
    }

    bool invalid(File self) {
        return !self.valid();
    }

    i32 close(File* self) {
        if ((*self).invalid()) {
            self.is_open = false;
            return 0;
        }
        SysResult r = try_close(self.fd);
        if (r.is_ok()) {
            self.fd = -1;
            self.is_open = false;
            return 0;
        }
        return (i32)r.errno;
    }

    /// No userspace buffer to flush: a valid fd is already flushed.
    i32 flush(File self) {
        if (self.invalid()) {
            return EOF;
        }
        return 0;
    }

    i32 read_char(File* self) {
        if ((*self).invalid()) {
            return EOF;
        }
        u8 ch = (u8)0;
        SysResult r = try_read(self.fd, &ch, 1);
        if (r.is_err()) {
            self.had_error = true;
            return EOF;
        }
        if (r.value == 0) {
            self.at_eof = true;
            return EOF;
        }
        return (i32)ch;
    }

    i32 write_char(File* self, i32 ch) {
        if ((*self).invalid()) {
            return EOF;
        }
        u8 b = (u8)ch;
        SysResult r = try_write(self.fd, &b, 1);
        if (r.is_err() || r.value != 1) {
            self.had_error = true;
            return EOF;
        }
        return ch;
    }

    i32 write_str(File* self, str text) {
        if ((*self).invalid()) {
            return EOF;
        }
        if (text == (str)0) {
            self.had_error = true;
            return EOF;
        }
        u8* p = (u8*)text;
        i64 len = cstr_len(p);
        i64 written = 0;
        while (written < len) {
            SysResult r = try_write(self.fd, (u8*)((i64)p + written), len - written);
            if (r.is_err()) {
                self.had_error = true;
                return EOF;
            }
            if (r.value == 0) {
                self.had_error = true;
                return EOF;
            }
            written = written + r.value;
        }
        return 0;
    }

    i32 write_line(File* self, str text) {
        if ((*self).invalid()) {
            return EOF;
        }
        i32 result = self.write_str(text);
        if (result < 0) {
            return result;
        }
        return self.write_char(10);
    }

    /// fread-shaped API: reads up to elem_size*elem_count bytes, returns
    /// whole elements read (0 at EOF or on error, like a short fread).
    i64 read(File* self, void* buffer, i64 elem_size, i64 elem_count) {
        if ((*self).invalid()) {
            return 0;
        }
        if (elem_size <= 0 || elem_count <= 0) {
            return 0;
        }
        i64 total = elem_size * elem_count;
        i64 done = 0;
        while (done < total) {
            SysResult r = try_read(self.fd, (u8*)((i64)buffer + done), total - done);
            if (r.is_err()) {
                self.had_error = true;
                break;
            }
            if (r.value == 0) {
                self.at_eof = true;
                break;
            }
            done = done + r.value;
        }
        return done / elem_size;
    }

    /// fwrite-shaped API: writes elem_size*elem_count bytes, returns whole
    /// elements written (short count on error, like fwrite).
    i64 write(File* self, const void* buffer, i64 elem_size, i64 elem_count) {
        if ((*self).invalid()) {
            return 0;
        }
        if (elem_size <= 0 || elem_count <= 0) {
            return 0;
        }
        i64 total = elem_size * elem_count;
        i64 done = 0;
        while (done < total) {
            SysResult r = try_write(self.fd, (u8*)((i64)buffer + done), total - done);
            if (r.is_err()) {
                self.had_error = true;
                break;
            }
            if (r.value == 0) {
                self.had_error = true;
                break;
            }
            done = done + r.value;
        }
        return done / elem_size;
    }

    bool seek(File* self, i64 offset) {
        return self.seek_from(offset, IO_SEEK.SET);
    }

    bool seek_to_start(File* self) {
        return self.seek_from(0, IO_SEEK.SET);
    }

    bool seek_to_end(File* self) {
        return self.seek_from(0, IO_SEEK.END);
    }

    bool seek_from(File* self, i64 offset, IO_SEEK origin) {
        if ((*self).invalid()) {
            return false;
        }
        SysResult r = try_lseek(self.fd, offset, (i64)((i32)origin));
        if (r.is_err()) {
            self.had_error = true;
            return false;
        }
        return true;
    }

    i64 tell(File* self) {
        if ((*self).invalid()) {
            return -1;
        }
        SysResult r = try_lseek(self.fd, 0, SEEK_CUR);
        if (r.is_err()) {
            self.had_error = true;
            return -1;
        }
        return r.value;
    }

    void rewind(File* self) {
        if ((*self).valid()) {
            self.seek_from(0, IO_SEEK.SET);
            self.at_eof = false;
            self.had_error = false;
        }
    }

    bool eof(File* self) {
        if ((*self).invalid()) {
            return true;
        }
        return self.at_eof;
    }

    bool error(File* self) {
        if ((*self).invalid()) {
            return true;
        }
        return self.had_error;
    }

    void clear_error(File* self) {
        if ((*self).valid()) {
            self.at_eof = false;
            self.had_error = false;
        }
    }

    i64 size(File* self) {
        if ((*self).invalid()) {
            return -1;
        }
        i64 pos = self.tell();
        if (pos < 0) {
            return -1;
        }
        SysResult end = try_lseek(self.fd, 0, SEEK_END);
        if (end.is_err()) {
            self.had_error = true;
            return -1;
        }
        self.seek_from(pos, IO_SEEK.SET);
        return end.value;
    }
}

// True when `needle` (a byte value) occurs in the null-terminated string `p`.
bool cstr_contains(u8* p, u8 needle) {
    i64 i = 0;
    while (p[i] != (u8)0) {
        if (p[i] == needle) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

// Convenience constructors for the standard descriptors.
File stdin_file() {
    return File.from_fd(STDIN_FD);
}

File stdout_file() {
    return File.from_fd(STDOUT_FD);
}

File stderr_file() {
    return File.from_fd(STDERR_FD);
}

// High-level helpers. These write straight through the write(2) syscall
// (std.fmt), bypassing libc stdio buffering entirely.
i32 println(str text) {
    if (text == (str)0) {
        return EOF;
    }
    u8* p = (u8*)text;
    i64 len = cstr_len(p);
    if (write_stdout(p, len) < 0) {
        return EOF;
    }
    if (write_stdout((u8*)"\n", 1) < 0) {
        return EOF;
    }
    return (i32)(len + 1);
}

i32 eprintln(str text) {
    if (text == (str)0) {
        return EOF;
    }
    u8* p = (u8*)text;
    i64 len = cstr_len(p);
    if (write_stderr(p, len) < 0) {
        return EOF;
    }
    if (write_stderr((u8*)"\n", 1) < 0) {
        return EOF;
    }
    return (i32)(len + 1);
}

bool file_exists(str path) {
    File file = File.open_read(path);
    if (file.invalid()) {
        return false;
    }
    file.close();
    return true;
}

bool file_delete(str path) {
    return remove(path) == 0;
}

bool file_rename(str from, str to) {
    return rename(from, to) == 0;
}
