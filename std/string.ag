extern "C" {
    void abort();
}
import std.mem.alloc;
import std.ops;

extern "C" {
    i64 strlen(const char* s);
    i32 memcmp(const void* s1, const void* s2, i64 n);
    i32 strcmp(const char* s1, const char* s2);
}

struct String {
    u8* data;
    i64 len;
    i64 capacity;
}

impl String {
    String new() {
        return String.with_capacity(16);
    }

    String with_capacity(i64 capacity) {
        String s;
        s.len = 0;
        s.capacity = capacity;
        if (capacity > 0) {
            s.data = alloc<u8>(capacity);
            s.data[0] = (u8)0;
        } else {
            s.data = (u8*)0;
        }
        return move s;
    }

    void drop(String* self) {
        if ((*self).data != (u8*)0) {
            free((*self).data);
            (*self).data = (u8*)0;
        }
        (*self).len = 0;
        (*self).capacity = 0;
    }

    i64 len(String* self) {
        return (*self).len;
    }

    i64 capacity(String* self) {
        return (*self).capacity;
    }

    void clear(String* self) {
        (*self).len = 0;
        if ((*self).data != (u8*)0) {
            (*self).data[0] = (u8)0;
        }
    }

    void push(String* self, u8 ch) {
        // Need space for the character plus the null terminator
        if ((*self).len + 2 > (*self).capacity) {
            i64 new_cap = (*self).capacity * 2;
            if (new_cap < 16) {
                new_cap = 16;
            }
            (*self).data = realloc<u8>((*self).data, new_cap);
            (*self).capacity = new_cap;
        }
        (*self).data[(*self).len] = ch;
        (*self).len = (*self).len + 1;
        (*self).data[(*self).len] = (u8)0;
    }

    void push_str(String* self, str text) {
        if (text == (str)0) {
            return;
        }
        i64 text_len = strlen(text);
        if (text_len == 0) {
            return;
        }
        if ((*self).len + text_len + 1 > (*self).capacity) {
            i64 new_cap = (*self).capacity * 2;
            if (new_cap < (*self).len + text_len + 16) {
                new_cap = (*self).len + text_len + 16;
            }
            (*self).data = realloc<u8>((*self).data, new_cap);
            (*self).capacity = new_cap;
        }
        memcpy((void*)&(*self).data[(*self).len], (const void*)text, text_len);
        (*self).len = (*self).len + text_len;
        (*self).data[(*self).len] = (u8)0;
    }

    // Clone borrows self (by pointer), creates a deep copy, and returns it.
    // The caller retains ownership of the original string.
    String clone(String* self) {
        String s = String.with_capacity((*self).capacity);
        s.len = (*self).len;
        if ((*self).len > 0) {
            memcpy((void*)s.data, (const void*)(*self).data, (*self).len);
            s.data[s.len] = (u8)0;
        }
        return move s;
    }

    bool equals(String* self, str other) {
        if (other == (str)0) {
            return false;
        }
        if ((*self).data == (u8*)0) {
            return strlen(other) == 0;
        }
        return strcmp((const char*)(*self).data, other) == 0;
    }

    const char* to_str(String* self) {
        if ((*self).data == (u8*)0) {
            return "";
        }
        return (const char*)(*self).data;
    }
}
impl IndexedAccess<String> for String {
    type Item = u8;
    u8 __index_get(String* self, i64 index) {
        if (index < 0 || index >= (*self).len) { abort(); }
        return (*self).data[index];
    }
    void __index_set(String* self, i64 index, u8 value) {
        if (index < 0 || index >= (*self).len) { abort(); }
        (*self).data[index] = value;
    }
}
