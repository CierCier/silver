// std/net/inet.ag — IPv4 address types and byte-order helpers (Linux x86_64).
//
// Provides the SockAddrIn type (wraps C `struct sockaddr_in`, 16 bytes,
// natural alignment) and pure-Silver helpers for network byte-order
// conversion and dotted-quad IPv4 string parsing.

import std.sys.result;

// --- SockAddrIn (struct sockaddr_in) ---
// Layout (16 bytes, 4-byte alignment, no padding holes):
//   offset 0: sin_family  (u16)
//   offset 2: sin_port    (u16)
//   offset 4: sin_addr    (u32)
//   offset 8: sin_zero_1  (u32)
//   offset 12: sin_zero_2 (u32)
pub struct SockAddrIn {
    u16 sin_family;
    u16 sin_port;
    u32 sin_addr;
    u32 sin_zero_1;
    u32 sin_zero_2;
}

impl SockAddrIn {
    // Construct a SockAddrIn from a port (host byte order) and dotted-quad
    // IPv4 string. The port is converted to network byte order internally.
    SockAddrIn v4(u16 port, str addr_str) {
        SockAddrIn sa;
        sa.sin_family = (u16)AF_INET;
        sa.sin_port = hton16(port);
        sa.sin_addr = (u32)ntoh32(inet_addr(addr_str));
        sa.sin_zero_1 = (u32)0;
        sa.sin_zero_2 = (u32)0;
        return move sa;
    }
}

// --- Byte-order helpers ---
//
// Silver lowers `>>` as arithmetic (signed) right shift. Every shift is
// followed by an `& 0xFF` / `& 0xFF00` mask to prevent sign-extension
// from corrupting high bytes.
// All intermediate math uses `i64` because bitwise operator operands
// (| & << >>) must have exactly the same type, and integer literals
// default to `i32` / `i64`.

// Host byte order -> network byte order (16-bit).
pub u16 hton16(u16 host) {
    i64 h = (i64)host;
    i64 r = ((h & (i64)0xFF) << (i64)8) | ((h >> (i64)8) & (i64)0xFF);
    return (u16)r;
}

// Network byte order -> host byte order (16-bit). Symmetric for 16-bit.
pub u16 ntoh16(u16 net) {
    return hton16(net);
}

// Host byte order -> network byte order (32-bit).
pub u32 hton32(u32 host) {
    i64 h = (i64)host;
    i64 r = ((h & (i64)0xFF) << (i64)24)
          | ((h & (i64)0xFF00) << (i64)8)
          | ((h >> (i64)8) & (i64)0xFF00)
          | ((h >> (i64)24) & (i64)0xFF);
    return (u32)r;
}

// Network byte order -> host byte order (32-bit). Symmetric for 32-bit.
pub u32 ntoh32(u32 net) {
    return hton32(net);
}

// --- IPv4 dotted-quad parser ---
//
// Parses `"a.b.c.d"` into a network-byte-order i64. Returns 0 on any invalid
// input (null string, non-digit characters, overflow, wrong number of octets).
// Uses i64 throughout (matching Silver's preferred integer type) with a final
// cast to u32 at the call site.

pub i64 inet_addr(str s) {
    if (s == (str)0) { return (i64)0; }
    u8* p = (u8*)s;
    i64 result = 0;
    i64 octet = 0;
    i64 shift = 24;
    i64 dots = 0;
    i64 i = 0;
    while (i < 16) {
        u8 c = p[i];
        if (c == (u8)0) {
            if (dots != 3) { return (i64)0; }
            result = result | (octet << shift);
            break;
        }
        if (c == (u8)46) {  // '.'
            if (dots >= 3 || octet > 255) { return (i64)0; }
            result = result | (octet << shift);
            octet = 0;
            shift -= 8;
            dots += 1;
        } else {
            if (c >= (u8)48 && c <= (u8)57) {
                octet = octet * 10 + ((i64)c - 48);
                if (octet > 255) { return (i64)0; }
            } else {
                return (i64)0;
            }
        }
        i += 1;
    }
    return result;
}

// ---------------------------------------------------------------------------
// IPv6
// ---------------------------------------------------------------------------

// struct sockaddr_in6 — 28 bytes, matches Linux x86_64 layout.
// Address stored as two u64 halves (network byte order).
pub struct SockAddrIn6 {
    u16 sin6_family;
    u16 sin6_port;
    u32 sin6_flowinfo;
    u64 sin6_addr_lo;   // bytes 0-7 of IPv6 address
    u64 sin6_addr_hi;   // bytes 8-15 of IPv6 address
    u32 sin6_scope_id;
}

impl SockAddrIn6 {
    /// Construct from port and colon-hex address string ("::1", "2001:db8::1", etc.).
    pub SockAddrIn6 v6(u16 port, str addr_str) {
        SockAddrIn6 sa;
        sa.sin6_family = (u16)AF_INET6;
        sa.sin6_port = hton16(port);
        sa.sin6_flowinfo = (u32)0;
        sa.sin6_scope_id = (u32)0;

        u64 hi = 0;
        u64 lo = 0;
        inet_pton6(addr_str, &hi, &lo);
        sa.sin6_addr_hi = hi;
        sa.sin6_addr_lo = lo;
        return move sa;
    }

    /// Set address from colon-hex string. Returns true on success.
    pub bool set_addr(SockAddrIn6* self, str addr_str) {
        u64 hi = 0;
        u64 lo = 0;
        bool ok = inet_pton6(addr_str, &hi, &lo);
        if (ok) {
            self.sin6_addr_hi = hi;
            self.sin6_addr_lo = lo;
        }
        return ok;
    }
}

/// Parse an IPv6 colon-hex string into two u64 halves (network byte order).
/// Handles :: compression, but NOT embedded IPv4 (::ffff:1.2.3.4).
/// Returns true on success.
pub bool inet_pton6(str s, u64* hi_out, u64* lo_out) {
    if (s == (str)0) { return false; }
    u8* p = (u8*)s;

    // 8 × 16-bit hextets stored in host order during parse.
    u16 hextets[8];
    i64 hpos = 0;     // next hextet index to fill
    i64 compress = -1; // index where :: was seen (-1 = none)

    i64 i = 0;
    while (p[i] != (u8)0 && hpos < 8) {
        if (p[i] == (u8)58) {  // ':'
            if (i > 0 && p[i-1] == (u8)58) {  // "::"
                if (compress != -1) { return false; }  // only one ::
                compress = hpos;
                i += 1;
                if (p[i] == (u8)0) { break; }  // trailing ::
                continue;
            }
            if (i == 0) {  // leading ':' without second ':' is invalid
                if (p[i+1] != (u8)58) { return false; }
                i += 1;
                continue;
            }
            i += 1;
            continue;
        }

        // Parse a hex hextet.
        u16 val = 0;
        i64 digits = 0;
        while (p[i] != (u8)0 && p[i] != (u8)58 && digits < 4) {
            u8 c = p[i];
            u8 d;
            if (c >= (u8)48 && c <= (u8)57)       { d = c - (u8)48; }
            else {
                if (c >= (u8)65 && c <= (u8)70)   { d = c - (u8)65 + (u8)10; }
                else {
                    if (c >= (u8)97 && c <= (u8)102) { d = c - (u8)97 + (u8)10; }
                    else { return false; }
                }
            }
            val = (val << (u16)4) | (u16)d;
            digits += 1;
            i += 1;
        }
        if (digits == 0) { return false; }
        hextets[hpos] = val;
        hpos += 1;
    }

    if (hpos >= 8 && p[i] != (u8)0) { return false; }

    // Expand :: compression.
    u16 out[8];
    if (compress != -1) {
        i64 gap = 8 - hpos;
        if (gap < 0) { return false; }
        i64 j = 0;
        i64 k = 0;
        while (j < compress)    { out[k] = hextets[j]; k += 1; j += 1; }
        while (gap > 0)         { out[k] = (u16)0;     k += 1; gap -= 1; }
        while (j < hpos)        { out[k] = hextets[j]; k += 1; j += 1; }
    } else {
        if (hpos != 8) { return false; }  // need exactly 8 hextets without ::
        i64 j = 0;
        while (j < 8) { out[j] = hextets[j]; j += 1; }
    }

    // Pack into two u64 in network byte order.
    // hextet[0..3] -> hi (bytes: h[0],h[1],h[2],h[3] in big-endian)
    // hextet[4..7] -> lo
    u64 hi = 0;
    u64 lo = 0;
    hi = hi | ((u64)out[0] << (u64)48);
    hi = hi | ((u64)out[1] << (u64)32);
    hi = hi | ((u64)out[2] << (u64)16);
    hi = hi | ((u64)out[3]);
    lo = lo | ((u64)out[4] << (u64)48);
    lo = lo | ((u64)out[5] << (u64)32);
    lo = lo | ((u64)out[6] << (u64)16);
    lo = lo | ((u64)out[7]);

    *hi_out = hi;
    *lo_out = lo;
    return true;
}
