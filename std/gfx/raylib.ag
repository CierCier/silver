#[link(raylib)]

const i32 RAYLIB_VERSION_MAJOR = 6;
const i32 RAYLIB_VERSION_MINOR = 0;
const i32 RAYLIB_VERSION_PATCH = 0;
const char* RAYLIB_VERSION = "6.0";

const f32 PI = 3.14159265358979323846;
const f32 DEG2RAD = 0.017453292519943295;
const f32 RAD2DEG = 57.29577951308232;

#[repr(C)]
struct Vector2 {
    f32 x;
    f32 y;
}

#[repr(C)]
struct Vector3 {
    f32 x;
    f32 y;
    f32 z;
}

#[repr(C)]
struct Vector4 {
    f32 x;
    f32 y;
    f32 z;
    f32 w;
}

#[repr(C)]
struct Quaternion {
    f32 x;
    f32 y;
    f32 z;
    f32 w;
}

#[repr(C)]
struct Matrix {
    f32 m0;
    f32 m4;
    f32 m8;
    f32 m12;
    f32 m1;
    f32 m5;
    f32 m9;
    f32 m13;
    f32 m2;
    f32 m6;
    f32 m10;
    f32 m14;
    f32 m3;
    f32 m7;
    f32 m11;
    f32 m15;
}

#[repr(C)]
struct Color {
    u8 r;
    u8 g;
    u8 b;
    u8 a;
}

#[repr(C)]
struct Rectangle {
    f32 x;
    f32 y;
    f32 width;
    f32 height;
}

#[repr(C)]
struct Image {
    void* data;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

#[repr(C)]
struct Texture {
    u32 id;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

#[repr(C)]
struct Texture2D {
    u32 id;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

#[repr(C)]
struct TextureCubemap {
    u32 id;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

#[repr(C)]
struct RenderTexture {
    u32 id;
    Texture texture;
    Texture depth;
}

#[repr(C)]
struct RenderTexture2D {
    u32 id;
    Texture texture;
    Texture depth;
}

#[repr(C)]
struct NPatchInfo {
    Rectangle source;
    i32 left;
    i32 top;
    i32 right;
    i32 bottom;
    i32 layout;
}

#[repr(C)]
struct GlyphInfo {
    i32 value;
    i32 offsetX;
    i32 offsetY;
    i32 advanceX;
    Image image;
}

#[repr(C)]
struct Font {
    i32 baseSize;
    i32 glyphCount;
    i32 glyphPadding;
    Texture2D texture;
    Rectangle* recs;
    GlyphInfo* glyphs;
}

#[repr(C)]
struct Camera3D {
    Vector3 position;
    Vector3 target;
    Vector3 up;
    f32 fovy;
    i32 projection;
}

#[repr(C)]
struct Camera {
    Vector3 position;
    Vector3 target;
    Vector3 up;
    f32 fovy;
    i32 projection;
}

#[repr(C)]
struct Camera2D {
    Vector2 offset;
    Vector2 target;
    f32 rotation;
    f32 zoom;
}

#[repr(C)]
struct Mesh {
    i32 vertexCount;
    i32 triangleCount;
    f32* vertices;
    f32* texcoords;
    f32* texcoords2;
    f32* normals;
    f32* tangents;
    u8* colors;
    u16* indices;
    i32 boneCount;
    u8* boneIndices;
    f32* boneWeights;
    f32* animVertices;
    f32* animNormals;
    u32 vaoId;
    u32* vboId;
}

#[repr(C)]
struct Shader {
    u32 id;
    i32* locs;
}

#[repr(C)]
struct MaterialMap {
    Texture2D texture;
    Color color;
    f32 value;
}

#[repr(C)]
struct Material {
    Shader shader;
    MaterialMap* maps;
    [f32; 4] params;
}

#[repr(C)]
struct Transform {
    Vector3 translation;
    Quaternion rotation;
    Vector3 scale;
}

#[repr(C)]
struct BoneInfo {
    [i8; 32] name;
    i32 parent;
}

#[repr(C)]
struct ModelSkeleton {
    i32 boneCount;
    BoneInfo* bones;
    Transform* bindPose;
}

#[repr(C)]
struct Model {
    Matrix transform;
    i32 meshCount;
    i32 materialCount;
    Mesh* meshes;
    Material* materials;
    i32* meshMaterial;
    ModelSkeleton skeleton;
    Transform* currentPose;
    Matrix* boneMatrices;
}

#[repr(C)]
struct ModelAnimation {
    [i8; 32] name;
    i32 boneCount;
    i32 keyframeCount;
    Transform** keyframePoses;
}

#[repr(C)]
struct Ray {
    Vector3 position;
    Vector3 direction;
}

#[repr(C)]
struct RayCollision {
    bool hit;
    f32 distance;
    Vector3 point;
    Vector3 normal;
}

#[repr(C)]
struct BoundingBox {
    Vector3 min;
    Vector3 max;
}

#[repr(C)]
struct Wave {
    u32 frameCount;
    u32 sampleRate;
    u32 sampleSize;
    u32 channels;
    void* data;
}

#[repr(C)]
struct rAudioBuffer {
    i32 _opaque;
}

#[repr(C)]
struct rAudioProcessor {
    i32 _opaque;
}

#[repr(C)]
struct AudioStream {
    rAudioBuffer* buffer;
    rAudioProcessor* processor;
    u32 sampleRate;
    u32 sampleSize;
    u32 channels;
}

#[repr(C)]
struct Sound {
    AudioStream stream;
    u32 frameCount;
}

#[repr(C)]
struct Music {
    AudioStream stream;
    u32 frameCount;
    bool looping;
    i32 ctxType;
    void* ctxData;
}

#[repr(C)]
struct VrDeviceInfo {
    i32 hResolution;
    i32 vResolution;
    f32 hScreenSize;
    f32 vScreenSize;
    f32 eyeToScreenDistance;
    f32 lensSeparationDistance;
    f32 interpupillaryDistance;
    [f32; 4] lensDistortionValues;
    [f32; 4] chromaAbCorrection;
}

#[repr(C)]
struct VrStereoConfig {
    [Matrix; 2] projection;
    [Matrix; 2] viewOffset;
    [f32; 2] leftLensCenter;
    [f32; 2] rightLensCenter;
    [f32; 2] leftScreenCenter;
    [f32; 2] rightScreenCenter;
    [f32; 2] scale;
    [f32; 2] scaleIn;
}

#[repr(C)]
struct FilePathList {
    u32 count;
    char** paths;
}

#[repr(C)]
struct AutomationEvent {
    u32 frame;
    u32 type;
    [i32; 4] params;
}

#[repr(C)]
struct AutomationEventList {
    u32 capacity;
    u32 count;
    AutomationEvent* events;
}

