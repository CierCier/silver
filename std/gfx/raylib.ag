//----------------------------------------------------------------------------------
// Module Functions Declaration
//----------------------------------------------------------------------------------

extern "C" {

// Window-related functions
void InitWindow(i32 width, i32 height, const char *title);
void CloseWindow();
bool WindowShouldClose();
bool IsWindowReady();
bool IsWindowFullscreen();
bool IsWindowHidden();
bool IsWindowMinimized();
bool IsWindowMaximized();
bool IsWindowFocused();
bool IsWindowResized();
bool IsWindowState(u32 flag);
void SetWindowState(u32 flags);
void ClearWindowState(u32 flags);
void ToggleFullscreen();
void ToggleBorderlessWindowed();
void MaximizeWindow();
void MinimizeWindow();
void RestoreWindow();
void SetWindowIcon(Image image);
void SetWindowIcons(Image *images, i32 count);
void SetWindowTitle(const char *title);
void SetWindowPosition(i32 x, i32 y);
void SetWindowMonitor(i32 monitor);
void SetWindowMinSize(i32 width, i32 height);
void SetWindowMaxSize(i32 width, i32 height);
void SetWindowSize(i32 width, i32 height);
void SetWindowOpacity(f32 opacity);
void SetWindowFocused();
void *GetWindowHandle();
i32 GetScreenWidth();
i32 GetScreenHeight();
i32 GetRenderWidth();
i32 GetRenderHeight();
i32 GetMonitorCount();
i32 GetCurrentMonitor();
Vector2 GetMonitorPosition(i32 monitor);
i32 GetMonitorWidth(i32 monitor);
i32 GetMonitorHeight(i32 monitor);
i32 GetMonitorPhysicalWidth(i32 monitor);
i32 GetMonitorPhysicalHeight(i32 monitor);
i32 GetMonitorRefreshRate(i32 monitor);
Vector2 GetWindowPosition();
Vector2 GetWindowScaleDPI();
const char *GetMonitorName(i32 monitor);
void SetClipboardText(const char *text);
const char *GetClipboardText();
Image GetClipboardImage();
void EnableEventWaiting();
void DisableEventWaiting();

// Cursor-related functions
void ShowCursor();
void HideCursor();
bool IsCursorHidden();
void EnableCursor();
void DisableCursor();
bool IsCursorOnScreen();

// Drawing-related functions
void ClearBackground(Color color);
void BeginDrawing();
void EndDrawing();
void BeginMode2D(Camera2D camera);
void EndMode2D();
void BeginMode3D(Camera3D camera);
void EndMode3D();
void BeginTextureMode(RenderTexture target);
void EndTextureMode();
void BeginShaderMode(Shader shader);
void EndShaderMode();
void BeginBlendMode(i32 mode);
void EndBlendMode();
void BeginScissorMode(i32 x, i32 y, i32 width, i32 height);
void EndScissorMode();
void BeginVrStereoMode(VrStereoConfig config);
void EndVrStereoMode();

// VR stereo config functions
VrStereoConfig LoadVrStereoConfig(VrDeviceInfo device);
void UnloadVrStereoConfig(VrStereoConfig config);

// Shader management functions
Shader LoadShader(const char *vsFileName, const char *fsFileName);
Shader LoadShaderFromMemory(const char *vsCode, const char *fsCode);
bool IsShaderValid(Shader shader);
i32 GetShaderLocation(Shader shader, const char *uniformName);
i32 GetShaderLocationAttrib(Shader shader, const char *attribName);
void SetShaderValue(Shader shader, i32 locIndex, const void *value, i32 uniformType);
void SetShaderValueV(Shader shader, i32 locIndex, const void *value, i32 uniformType, i32 count);
void SetShaderValueMatrix(Shader shader, i32 locIndex, Matrix mat);
void SetShaderValueTexture(Shader shader, i32 locIndex, Texture texture);
void UnloadShader(Shader shader);

// Screen-space-related functions
Ray GetScreenToWorldRay(Vector2 position, Camera3D camera);
Ray GetScreenToWorldRayEx(Vector2 position, Camera3D camera, i32 width, i32 height);
Vector2 GetWorldToScreen(Vector3 position, Camera3D camera);
Vector2 GetWorldToScreenEx(Vector3 position, Camera3D camera, i32 width, i32 height);
Vector2 GetWorldToScreen2D(Vector2 position, Camera2D camera);
Vector2 GetScreenToWorld2D(Vector2 position, Camera2D camera);
Matrix GetCameraMatrix(Camera3D camera);
Matrix GetCameraMatrix2D(Camera2D camera);

// Timing-related functions
void SetTargetFPS(i32 fps);
f32 GetFrameTime();
f64 GetTime();
i32 GetFPS();

// Custom frame control functions
void SwapScreenBuffer();
void PollInputEvents();
void WaitTime(f64 seconds);

// Random values generation functions
void SetRandomSeed(u32 seed);
i32 GetRandomValue(i32 min, i32 max);
i32 *LoadRandomSequence(u32 count, i32 min, i32 max);
void UnloadRandomSequence(i32 *sequence);

// Misc. functions
void TakeScreenshot(const char *fileName);
void SetConfigFlags(u32 flags);
void OpenURL(const char *url);

// Logging system
void SetTraceLogLevel(i32 logLevel);
void TraceLog(i32 logLevel, const char *text, ...);

// Memory management
void *MemAlloc(u32 size);
